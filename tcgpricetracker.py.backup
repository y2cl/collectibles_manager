def add_to_watchlist_csv(game: str, name: str, set_name: str, link: str, image_url: str,
                         price_low: Optional[float], price_mid: Optional[float], price_market: Optional[float],
                         variant: Optional[str] = None):
    ts = datetime.now().isoformat()
    df = load_watchlist_dataframe()
    new_row = {
        "timestamp": ts,
        "game": game,
        "name": name,
        "set": set_name,
        "link": link,
        "image_url": image_url,
        "price_low": price_low,
        "price_mid": price_mid,
        "price_market": price_market,
        "variant": variant
    }
    df = pd.concat([df, pd.DataFrame([new_row])], ignore_index=True)
    save_watchlist_dataframe(df)


def load_collection_prices_history():
    if os.path.exists(COLLECTION_PRICES_HISTORY_PATH):
        return pd.read_csv(COLLECTION_PRICES_HISTORY_PATH)
    else:
        return pd.DataFrame(columns=["timestamp", "game", "name", "set", "quantity", "variant", "price_low", "price_mid", "price_market"])


def save_collection_prices_history(df):
    df.to_csv(COLLECTION_PRICES_HISTORY_PATH, index=False)


def refresh_collection_prices(dfc: pd.DataFrame) -> pd.DataFrame:
    refreshed = dfc.copy()
    for idx, row in dfc.iterrows():
        game = row.get("game", "")
        name = row.get("name", "")
        set_name = row.get("set", "")
        if not name:
            continue
        try:
            if game == "Magic: The Gathering":
                cards = scryfall_search_all(name.strip(), set_name.strip() if set_name else None, None)
                if cards:
                    # Find best match by set if provided
                    card = cards[0]
                    if set_name:
                        for c in cards:
                            if c.get("set_name", "").lower() == set_name.lower():
                                card = c
                                break
                    ps = scryfall_card_price_summary(card)
                    refreshed.at[idx, "price_low"] = ps.get("usd")
                    refreshed.at[idx, "price_mid"] = ps.get("usd")  # Scryfall only gives usd
                    refreshed.at[idx, "price_market"] = ps.get("usd")
                    refreshed.at[idx, "price_usd"] = ps.get("usd")
                    refreshed.at[idx, "price_usd_foil"] = ps.get("usd_foil")
                    refreshed.at[idx, "price_usd_etched"] = ps.get("usd_etched")
            elif game == "Pokémon":
                cards, _, _, _ = pokemontcg_search_multi_source(name.strip(), set_name.strip() if set_name else None, None, pokemon_api_key=get_secret("POKEMONTCG_API_KEY"), justtcg_api_key=get_secret("JUSTTCG_API_KEY"), limit=10)
                if cards:
                    card = cards[0]
                    if set_name:
                        for c in cards:
                            # Handle both nested dict structure (Pokemon API) and flat string structure (Baseball/eBay)
                            set_data = c.get("set")
                            if isinstance(set_data, dict):
                                current_set_name = set_data.get("name", "")
                            else:
                                current_set_name = c.get("set_name") or set_data or ""
                            
                            if current_set_name.lower() == set_name.lower():
                                card = c
                                break
                    ps = pokemontcg_price_summary(card)
                    refreshed.at[idx, "price_low"] = ps.get("low")
                    refreshed.at[idx, "price_mid"] = ps.get("mid")
                    refreshed.at[idx, "price_market"] = ps.get("market")
        except Exception as e:
            st.warning(f"Failed to refresh {name}: {e}")
    return refreshed

def snapshot_collection_prices():
    dfc = load_collection_dataframe()
    if dfc.empty:
        return
    ts = datetime.now().isoformat()
    history = load_collection_prices_history()
    for _, row in dfc.iterrows():
        new_row = {
            "timestamp": ts,
            "game": row.get("game", ""),
            "name": row.get("name", ""),
            "set": row.get("set", ""),
            "quantity": row.get("quantity", 0),
            "variant": row.get("variant", ""),
            "price_low": row.get("price_low", ""),
            "price_mid": row.get("price_mid", ""),
            "price_market": row.get("price_market", "")
        }
        history = pd.concat([history, pd.DataFrame([new_row])], ignore_index=True)
    save_collection_prices_history(history)


def load_collection_dataframe() -> pd.DataFrame:
    """Load collection data from separate CSV files for each game"""
    all_data = []
    
    # Load Pokemon collection
    try:
        if os.path.exists(POKEMON_COLLECTION_CSV_PATH):
            pokemon_df = pd.read_csv(POKEMON_COLLECTION_CSV_PATH)
            if not pokemon_df.empty:
                all_data.append(pokemon_df)
    except Exception as e:
        print(f"Error loading Pokemon collection: {e}")
    
    # Load MTG collection
    try:
        if os.path.exists(MTG_COLLECTION_CSV_PATH):
            mtg_df = pd.read_csv(MTG_COLLECTION_CSV_PATH)
            if not mtg_df.empty:
                all_data.append(mtg_df)
    except Exception as e:
        print(f"Error loading MTG collection: {e}")
    
    # Combine all data
    if all_data:
        combined_df = pd.concat(all_data, ignore_index=True)
        # Ensure all required columns exist
        required_columns = ["game", "name", "set", "link", "image_url", "quantity", "variant"]
        for col in required_columns:
            if col not in combined_df.columns:
                combined_df[col] = ""
        return combined_df
    else:
        return pd.DataFrame(columns=["game", "name", "set", "link", "image_url", "quantity", "variant"])


def clear_collection_csv():
    """Clear all collection CSV files"""
    try:
        if os.path.exists(POKEMON_COLLECTION_CSV_PATH):
            os.remove(POKEMON_COLLECTION_CSV_PATH)
        if os.path.exists(MTG_COLLECTION_CSV_PATH):
            os.remove(MTG_COLLECTION_CSV_PATH)
    except Exception:
        pass


def migrate_old_collection():
    """Migrate cards from old tcg_collection.csv to new separate files"""
    old_collection_path = os.path.join(os.path.dirname(__file__), "tcg_collection.csv")
    
    if not os.path.exists(old_collection_path):
        return  # No old file to migrate
    
    try:
        # Load old collection
        old_df = pd.read_csv(old_collection_path)
        
        if old_df.empty:
            return  # No data to migrate
        
        # Load existing new collections (if any)
        existing_df = load_collection_dataframe()
        
        # Combine old data with existing data
        combined_df = pd.concat([existing_df, old_df], ignore_index=True)
        
        # Remove duplicates (based on name, set, and game)
        combined_df = combined_df.drop_duplicates(subset=['name', 'set', 'game'], keep='last')
        
        # Save to new separate files
        save_collection_dataframe(combined_df)
        
        # Backup old file and remove it
        backup_path = old_collection_path.replace('.csv', '_backup.csv')
        os.rename(old_collection_path, backup_path)
        
        print(f"Migrated {len(old_df)} cards from old collection to new format")
        print(f"Old collection backed up to: {backup_path}")
        
    except Exception as e:
        print(f"Error migrating old collection: {e}")


def load_collection_dataframe() -> pd.DataFrame:
    """Load collection data from separate CSV files for each game"""
    # First, check if we need to migrate old data
    migrate_old_collection()
    
    all_data = []
    
    # Load Pokemon collection
    try:
        if os.path.exists(POKEMON_COLLECTION_CSV_PATH):
            pokemon_df = pd.read_csv(POKEMON_COLLECTION_CSV_PATH)
            if not pokemon_df.empty:
                all_data.append(pokemon_df)
    except Exception as e:
        print(f"Error loading Pokemon collection: {e}")
    
    # Load MTG collection
    try:
        if os.path.exists(MTG_COLLECTION_CSV_PATH):
            mtg_df = pd.read_csv(MTG_COLLECTION_CSV_PATH)
            if not mtg_df.empty:
                all_data.append(mtg_df)
    except Exception as e:
        print(f"Error loading MTG collection: {e}")
    
    # Load Baseball collection
    try:
        if os.path.exists(BASEBALL_COLLECTION_CSV_PATH):
            baseball_df = pd.read_csv(BASEBALL_COLLECTION_CSV_PATH)
            if not baseball_df.empty:
                all_data.append(baseball_df)
    except Exception as e:
        print(f"Error loading Baseball collection: {e}")
    
    # Combine all data
    if all_data:
        combined_df = pd.concat(all_data, ignore_index=True)
        # Ensure all required columns exist
        required_columns = ["game", "name", "set", "link", "image_url", "quantity", "variant"]
        for col in required_columns:
            if col not in combined_df.columns:
                combined_df[col] = ""
        return combined_df
    else:
        return pd.DataFrame(columns=["game", "name", "set", "link", "image_url", "quantity", "variant"])


def save_collection_dataframe(df: pd.DataFrame):
    """Save collection data to separate CSV files based on game type"""
    # Basic sanitation: ensure integer quantity when possible
    if "quantity" in df.columns:
        try:
            df["quantity"] = pd.to_numeric(df["quantity"], errors="coerce").fillna(0).astype(int)
        except Exception:
            pass
    
    # Split data by game type
    pokemon_data = df[df["game"].str.contains("Pokémon|Pokemon", case=False, na=False)]
    mtg_data = df[df["game"].str.contains("Magic", case=False, na=False)]
    baseball_data = df[df["game"].str.contains("Baseball", case=False, na=False)]
    
    # Save Pokemon collection
    if not pokemon_data.empty:
        pokemon_data.to_csv(POKEMON_COLLECTION_CSV_PATH, index=False)
    elif os.path.exists(POKEMON_COLLECTION_CSV_PATH):
        # Remove file if no Pokemon cards
        os.remove(POKEMON_COLLECTION_CSV_PATH)
    
    # Save MTG collection
    if not mtg_data.empty:
        mtg_data.to_csv(MTG_COLLECTION_CSV_PATH, index=False)
    elif os.path.exists(MTG_COLLECTION_CSV_PATH):
        # Remove file if no MTG cards
        os.remove(MTG_COLLECTION_CSV_PATH)
    
    # Save Baseball collection
    if not baseball_data.empty:
        baseball_data.to_csv(BASEBALL_COLLECTION_CSV_PATH, index=False)
    elif os.path.exists(BASEBALL_COLLECTION_CSV_PATH):
        # Remove file if no Baseball cards
        os.remove(BASEBALL_COLLECTION_CSV_PATH)


