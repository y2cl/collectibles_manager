def render_pokemon_grid(cards: List[Dict], per_row: int = 3, image_width: int = CARD_IMAGE_WIDTH):
    for i in range(0, len(cards), per_row):
        cols = st.columns(per_row)
        for j in range(per_row):
            idx = i + j
            if idx >= len(cards):
                break
            c = cards[idx]
            name = c.get("name")
            # Handle both nested dict structure (Pokemon API) and flat string structure (Baseball/eBay)
            set_data = c.get("set")
            if isinstance(set_data, dict):
                set_full = set_data.get("name")
            else:
                set_full = c.get("set_name") or set_data
            url = (c.get("tcgplayer") or {}).get("url") or c.get("images", {}).get("large") or c.get("link")
            img_url = get_pokemontcg_image_url(c)
            with cols[j]:
                left, right = st.columns([1, 2])
                with left:
                    if img_url:
                        render_clickable_image(img_url, image_width)
                    else:
                        render_clickable_image("https://via.placeholder.com/200x280", image_width)
                with right:
                    st.markdown(f"**{name or 'Unknown Card'}**")
                    if set_full:
                        st.caption(set_full)
                    if c.get("fallback"):
                        st.caption("🔄 Using cached data")
                    elif c.get("alternative_source"):
                        st.caption("🌐 Alternative source")
                    if url:
                        st.markdown(f"[View]({url})")
                    # Card details
                    pkmn_set = c.get("set") or {}
                    if isinstance(pkmn_set, dict):
                        pkmn_total = pkmn_set.get("total")
                        pkmn_num = c.get('number') or c.get('card_number') or '-'
                        st.caption(f"Set number: {pkmn_num}/{pkmn_total}" if pkmn_total else f"Set number: {pkmn_num}")
                        st.caption(f"Rarity: {c.get('rarity') or '-'}")
                        # Artist
                        artist = c.get('artist')
                        if artist:
                            st.caption(f"Artist: {artist}")
                        # Release year from set data
                        release_date = pkmn_set.get("releaseDate")
                        if release_date:
                            try:
                                year = release_date.split('-')[0]
                                st.caption(f"Released: {year}")
                            except Exception:
                                pass
                    else:
                        # Handle flat structure (baseball cards)
                        if c.get("card_number"):
                            st.caption(f"Card #: {c.get('card_number')}")
                        if c.get("year"):
                            st.caption(f"Year: {c.get('year')}")
                        if c.get("team"):
                            st.caption(f"Team: {c.get('team')}")
                        if c.get("variety"):
                            st.caption(f"Variety: {c.get('variety')}")
                    # Prices
                    ps = {"low": None, "mid": None, "market": None}  # Initialize ps for all card types
                    if c.get("game") == "Baseball Cards":
                        # Baseball card pricing
                        price = c.get("price_usd", 0)
                        st.markdown(f"Price: ${price:.2f}" if price > 0 else "Price: -")
                        ps = {"low": price, "mid": price, "market": price}  # Use same format for consistency
                    else:
                        # Pokemon pricing
                        ps = pokemontcg_price_summary(c)
                        pcols = st.columns(3)
                        pcols[0].markdown(f"Low: {ps['low']:.2f}" if ps["low"] is not None else "Low: -")
                        pcols[1].markdown(f"Mid: {ps['mid']:.2f}" if ps["mid"] is not None else "Mid: -")
                        pcols[2].markdown(f"Market: {ps['market']:.2f}" if ps["market"] is not None else "Market: -")
                # Actions
                pkmn_variant = st.text_input("Variant (optional)", value="", key=f"wl_pkmn_variant_{i}_{j}")
                
                # Prepare card data for handlers
                card_data = {
                    "game": "Pokémon",
                    "name": name or "",
                    "set_name": set_full or "",
                    "link": url or "",
                    "image_url": img_url or "",
                    "prices": {"low": ps.get("low"), "mid": ps.get("mid"), "market": ps.get("market")}
                }
                
                # Use standardized handlers
                render_add_to_collection_button(
                    card_data=card_data,
                    button_key=f"add_pkmn_grid_{i}_{j}",
                    quantity_key=f"qty_pkmn_grid_{i}_{j}",
                    variant=pkmn_variant or ""
                )
                render_add_to_watchlist_button(
                    card_data=card_data,
                    button_key=f"wl_pkmn_grid_{i}_{j}"
                )

def render_mtg_list(cards: List[Dict], image_width: int = CARD_IMAGE_WIDTH):
    for c in cards:
        name = c.get("name")
        set_full = c.get("set_name")
        uri = c.get("scryfall_uri")
        img_url = get_scryfall_image_url(c)
        cols = st.columns([1, 2])
        with cols[0]:
            if img_url:
                render_clickable_image(img_url, image_width)
        with cols[1]:
            st.markdown(f"**{name or 'Unknown Card'}**")
            if set_full:
                st.caption(set_full)
            if uri:
                st.markdown(f"[View on Scryfall]({uri})")
            # Prices
            ps = scryfall_card_price_summary(c)
            # Use standardized price display handler
            render_card_price_display(
                game="Magic: The Gathering",
                prices=ps
            )
            mtg_variants = []
            if ps.get("usd") is not None:
                mtg_variants.append("nonfoil")
            if ps.get("usd_foil") is not None:
                mtg_variants.append("foil")
            if ps.get("usd_etched") is not None:
                mtg_variants.append("etched")
            # Use standardized variant selector
            variant_sel = render_variant_selector(
                game="Magic: The Gathering",
                prices={"usd": ps.get("usd"), "usd_foil": ps.get("usd_foil"), "usd_etched": ps.get("usd_etched")},
                selector_key=f"mtg_var_list_{(name or '')}_{(set_full or '')}"
            )
            
            # Prepare card data for handlers
            card_data = {
                "game": "Magic: The Gathering",
                "name": name or "",
                "set_name": set_full or "",
                "link": uri or "",
                "image_url": img_url or "",
                "prices": {"usd": ps.get("usd"), "usd_foil": ps.get("usd_foil"), "usd_etched": ps.get("usd_etched")}
            }
            
            # Use standardized handlers
            render_add_to_collection_button(
                card_data=card_data,
                button_key=f"add_mtg_list_{(name or '')}_{(set_full or '')}",
                quantity_key=f"qty_mtg_list_{(name or '')}_{(set_full or '')}",
                variant=variant_sel
            )
            render_add_to_watchlist_button(
                card_data=card_data,
                button_key=f"wl_mtg_list_{(name or '')}_{(set_full or '')}"
            )
        st.divider()

def render_pokemon_list(cards: List[Dict], image_width: int = CARD_IMAGE_WIDTH):
    for idx, c in enumerate(cards):
        name = c.get("name")
        # Handle both nested dict structure (Pokemon API) and flat string structure (Baseball/eBay)
        set_data = c.get("set")
        if isinstance(set_data, dict):
            set_full = set_data.get("name")
        else:
            set_full = c.get("set_name") or set_data
        url = (c.get("tcgplayer") or {}).get("url") or c.get("images", {}).get("large") or c.get("link")
        img_url = get_pokemontcg_image_url(c)
        cols = st.columns([1, 2])
        with cols[0]:
            if img_url:
                render_clickable_image(img_url, image_width)
            else:
                render_clickable_image("https://via.placeholder.com/200x280", image_width)
        with cols[1]:
            st.markdown(f"**{name or 'Unknown Card'}**")
            if set_full:
                st.caption(set_full)
            if c.get("fallback"):
                st.caption("🔄 Using cached data")
            elif c.get("alternative_source"):
                st.caption("🌐 Alternative source")
            if url:
                st.markdown(f"[View]({url})")
            # Card details
            pkmn_set = c.get("set") or {}
            if isinstance(pkmn_set, dict):
                pkmn_total = pkmn_set.get("total")
                pkmn_num = c.get('number') or c.get('card_number') or '-'
                st.caption(f"Set number: {pkmn_num}/{pkmn_total}" if pkmn_total else f"Set number: {pkmn_num}")
                st.caption(f"Rarity: {c.get('rarity') or '-'}")
                # Artist
                artist = c.get('artist')
                if artist:
                    st.caption(f"Artist: {artist}")
                # Release year from set data
                release_date = pkmn_set.get("releaseDate")
                if release_date:
                    try:
                        year = release_date.split('-')[0]
                        st.caption(f"Released: {year}")
                    except Exception:
                        pass
            else:
                # Handle flat structure (baseball cards)
                if c.get("card_number"):
                    st.caption(f"Card #: {c.get('card_number')}")
                if c.get("year"):
                    st.caption(f"Year: {c.get('year')}")
                if c.get("team"):
                    st.caption(f"Team: {c.get('team')}")
                if c.get("variety"):
                    st.caption(f"Variety: {c.get('variety')}")
            # Prices
            if c.get("game") == "Baseball Cards":
                # Baseball card pricing
                price = c.get("price_usd", 0)
                st.markdown(f"Price: ${price:.2f}" if price > 0 else "Price: -")
            else:
                # Pokemon pricing
                ps = pokemontcg_price_summary(c)
                pcols = st.columns(3)
                pcols[0].markdown(f"Low: {ps['low']:.2f}" if ps["low"] is not None else "Low: -")
                pcols[1].markdown(f"Mid: {ps['mid']:.2f}" if ps["mid"] is not None else "Mid: -")
                pcols[2].markdown(f"Market: {ps['market']:.2f}" if ps["market"] is not None else "Market: -")
        st.divider()
        # Variant prices section (only for Pokemon cards)
        if c.get("game") != "Baseball Cards":
            tp = (c.get("tcgplayer") or {}).get("prices") or {}
            # Debug: Show if variant prices data exists
            if st.session_state.get("debug_mode", False):
                st.write(f"Debug: TCGPlayer prices data: {tp}")
            if tp:  # Only show expander if there's variant data
                with st.expander("Variant prices"):
                    for variant, vals in tp.items():
                        low = _to_float(vals.get("low"))
                        mid = _to_float(vals.get("mid"))
                        market = _to_float(vals.get("market"))
                        row = st.columns([2, 1, 1, 1, 1, 1.5])
                        row[0].markdown(f"**{variant}**")
                        row[1].markdown(f"Low: {low}" if low is not None else "Low: -")
                        row[2].markdown(f"Mid: {mid}" if mid is not None else "Mid: -")
                        row[3].markdown(f"Mkt: {market}" if market is not None else "Mkt: -")
                        vqty = row[4].number_input("Qty", min_value=1, max_value=999, value=1, step=1, key=f"qty_pkmn_list_var_{idx}_{(name or '')}_{(set_full or '')}_{variant}")
                        if row[5].button("Add", key=f"add_pkmn_var_list_{idx}_{(name or '')}_{(set_full or '')}_{variant}"):
                            ok, msg = add_to_collection(
                                game="Pokémon",
                                name=name or "",
                                set_name=set_full or "",
                                link=url or "",
                                image_url=img_url or "",
                                prices={"low": low, "mid": mid, "market": market},
                                quantity=vqty,
                                variant=variant,
                            )
                            if ok:
                                st.session_state["last_added"] = {"name": name or "", "set": set_full or "", "quantity": int(vqty), "variant": variant}
                                st.toast("Variant added to collection")
                                st.rerun()
                            else:
                                st.error(f"Failed to save: {msg}")
                cv = st.columns([2.5, 1, 1.6])
                custom_variant = cv[0].text_input(
                    "Custom variant",
                    placeholder="e.g., Cracked Ice Holo",
                    key=f"cv_pkmn_list_{idx}_{(name or '')}_{(set_full or '')}",
                )
                cqty = cv[1].number_input(
                    "Qty",
                    min_value=1,
                    max_value=999,
                    value=1,
                    step=1,
                    key=f"cqty_pkmn_list_{idx}_{(name or '')}_{(set_full or '')}",
                )
                if cv[2].button("Add custom", key=f"cadd_pkmn_list_{idx}_{(name or '')}_{(set_full or '')}"):
                    if not (custom_variant or "").strip():
                        st.warning("Enter a custom variant name")
                    else:
                        ok, msg = add_to_collection(
                            game="Pokémon",
                            name=name or "",
                            set_name=set_full or "",
                            link=url or "",
                            image_url=img_url or "",
                            prices={"low": None, "mid": None, "market": None},
                            quantity=cqty,
                            variant=(custom_variant or "").strip(),
                        )
                        if ok:
                            st.session_state["last_added"] = {"name": name or "", "set": set_full or "", "quantity": int(cqty), "variant": (custom_variant or "").strip()}
                            st.toast("Custom variant added to collection")
                            st.rerun()
                        else:
                            st.error(f"Failed to save: {msg}")
            
            # Pokémon: optional variant entry for watchlist
            pkmn_variant2 = st.text_input(
                "Variant (optional)",
                value="",
                key=f"wl_pkmn_variant_list_{idx}_{(name or '')}_{(set_full or '')}",
            )
            
            # Prepare card data for handlers
            card_data = {
                "game": "Pokémon",
                "name": name or "",
                "set_name": set_full or "",
                "link": url or "",
                "image_url": img_url or "",
                "prices": {"low": ps.get("low"), "mid": ps.get("mid"), "market": ps.get("market")}
            }
            
            # Use standardized handlers
            render_add_to_collection_button(
                card_data=card_data,
                button_key=f"add_pkmn_list_{idx}_{(name or '')}_{(set_full or '')}",
                quantity_key=f"qty_pkmn_list_{idx}_{(name or '')}_{(set_full or '')}",
                variant=(pkmn_variant2 or "").strip()
            )
            render_add_to_watchlist_button(
                card_data=card_data,
                button_key=f"wl_pkmn_list_{idx}_{(name or '')}_{(set_full or '')}"
            )


def get_scryfall_image_url(card: Dict) -> Optional[str]:
    # Prefer large, then normal; handle MDFC via card_faces
    try:
        imgs = card.get("image_uris") or {}
        for key in ("large", "normal", "png"):
            if imgs.get(key):
                return imgs[key]
        faces = card.get("card_faces") or []
        if faces:
            imgs = faces[0].get("image_uris") or {}
            for key in ("large", "normal", "png"):
                if imgs.get(key):
                    return imgs[key]
    except Exception:
        pass
    return None


def get_pokemontcg_image_url(card: Dict) -> Optional[str]:
    try:
        imgs = card.get("images") or {}
        return imgs.get("large") or imgs.get("small")
    except Exception:
        return None


def ensure_lightbox():
    st.markdown(
        """
<style>
.lightbox { display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.9); }
.lightbox-content { margin: auto; display: block; max-width: 90%; max-height: 90%; }
.close { position: absolute; top: 15px; right: 35px; color: #f1f1f1; font-size: 40px; font-weight: bold; cursor: pointer; }
</style>
<div id="lightbox" class="lightbox" onclick="this.style.display='none'"><img class="lightbox-content" id="lightbox-img"><span class="close">&times;</span></div>
<script>
function openLightbox(src) { document.getElementById('lightbox').style.display='block'; document.getElementById('lightbox-img').src=src; }
</script>
        """,
        unsafe_allow_html=True,
    )

def render_clickable_image(img_url: str, width: int = CARD_IMAGE_WIDTH):
    if img_url:
        escaped_url = img_url.replace('"', '&quot;')
        st.markdown(
            f'<img src="{img_url}" width="{width}" style="cursor:pointer" onclick="openLightbox(\'{escaped_url}\')" />',
            unsafe_allow_html=True,
        )

