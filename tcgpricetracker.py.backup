# Card Data Storage Functions
def get_card_data_path(game: str) -> str:
    """Get path for card data CSV file"""
    script_dir = os.path.dirname(os.path.abspath(__file__))
    if "Pokémon" in game or "Pokemon" in game:
        return os.path.join(script_dir, "fallback_data", "Pokemon", "pokemon_cards_cache.csv")
    else:
        return os.path.join(script_dir, "fallback_data", "MTG", "mtg_cards_cache.csv")


def save_card_to_cache(game: str, card_data: Dict) -> None:
    """Save card data to cache with timestamp"""
    try:
        # Add timestamp
        card_data['cached_at'] = datetime.now().isoformat()
        
        # Get cache file path
        cache_path = get_card_data_path(game)
        
        # Create directory if it doesn't exist
        os.makedirs(os.path.dirname(cache_path), exist_ok=True)
        
        # Load existing cache or create new
        if os.path.exists(cache_path):
            cache_df = pd.read_csv(cache_path)
        else:
            cache_df = pd.DataFrame()
        
        # Check if card already exists (by name and set)
        existing_mask = (cache_df['name'] == card_data.get('name', '')) & \
                       (cache_df['set'] == card_data.get('set', ''))
        
        if existing_mask.any():
            # Update existing card
            cache_df.loc[existing_mask, card_data.keys()] = card_data.values()
        else:
            # Add new card
            new_row = pd.DataFrame([card_data])
            cache_df = pd.concat([cache_df, new_row], ignore_index=True)
        
        # Save to CSV
        cache_df.to_csv(cache_path, index=False)
        
    except Exception as e:
        print(f"Error saving card to cache: {e}")


def batch_save_cards_to_cache(game: str, cards: List[Dict]) -> None:
    """Save multiple cards to cache with timestamps"""
    try:
        if not cards:
            return
        
        # Get cache file path
        cache_path = get_card_data_path(game)
        
        # Create directory if it doesn't exist
        os.makedirs(os.path.dirname(cache_path), exist_ok=True)
        
        # Load existing cache or create new
        if os.path.exists(cache_path):
            cache_df = pd.read_csv(cache_path)
        else:
            cache_df = pd.DataFrame()
        
        # Add timestamps to all cards
        timestamp = datetime.now().isoformat()
        for card in cards:
            card['cached_at'] = timestamp
        
        # Convert to DataFrame
        new_cards_df = pd.DataFrame(cards)
        
        # Merge with existing cache (update existing, add new)
        if not cache_df.empty:
            # Remove existing cards that are being updated
            cache_df = cache_df[~((cache_df['name'].isin(new_cards_df['name'])) & 
                                 (cache_df['set'].isin(new_cards_df['set'])))]
        
        # Combine and save
        combined_df = pd.concat([cache_df, new_cards_df], ignore_index=True)
        combined_df.to_csv(cache_path, index=False)
        
        print(f"Saved {len(cards)} {game} cards to cache")
        
    except Exception as e:
        print(f"Error batch saving cards to cache: {e}")


def download_and_cache_card_images(game: str, cards: List[Dict]) -> None:
    """Download and cache images for a list of cards"""
    try:
        downloaded_count = 0
        for card in cards:
            card_name = card.get('name', '')
            set_name = card.get('set', '')
            image_url = card.get('image_url', '')
            
            if image_url and image_url.startswith('http'):
                local_path = store_card_image_locally(game, card_name, set_name, image_url)
                if local_path != image_url:  # Successfully downloaded
                    downloaded_count += 1
        
        print(f"Downloaded {downloaded_count} new images for {game}")
        
    except Exception as e:
        print(f"Error downloading card images: {e}")


def process_search_results(game: str, cards: List[Dict]) -> List[Dict]:
    """Process search results: save to cache, download images, and return cards"""
    if not cards:
        return cards
    
    # Save card data to cache
    batch_save_cards_to_cache(game, cards)
    
    # Download images in background (don't block UI)
    download_and_cache_card_images(game, cards)
    
    return cards


# SportsCardDatabase.com Scraper Functions
def search_sportscard_database(player_name: str, year: str = "", set_name: str = "", card_number: str = "") -> Tuple[List[Dict], int, int, str]:
    """Search SportsCardDatabase.com for baseball cards"""
    try:
        base_url = "http://www.sportscarddatabase.com"
        
        print(f"🔍 Searching SportsCardDatabase for: {player_name}")
        print(f"📋 Filters - Year: '{year}', Set: '{set_name}', Card #: '{card_number}'")
        st.info("🔍 Searching SportsCardDatabase.com...")
        
        # Step 1: Find player ID
        player_id = find_player_id(player_name)
        if not player_id:
            print("❌ Player not found on SportsCardDatabase")
            st.warning("❌ Player not found on SportsCardDatabase")
            return [], 0, 0, "Player not found"
        
        print(f"👤 Found player ID: {player_id}")
        
        # Step 2: Get player's cards
        with st.spinner(f"📋 Getting {player_name}'s cards from SportsCardDatabase..."):
            cards = get_player_cards(player_id, player_name, year, set_name, card_number)
        
        print(f"📊 Raw cards found: {len(cards)}")
        
        if not cards:
            print("❌ No cards found for player with current filters")
            st.warning("❌ No cards found for this player with the specified filters")
            st.info("💡 Try with fewer filters (e.g., just player name)")
            return [], 0, 0, "No cards found"
        
        print(f"✅ Found {len(cards)} cards from SportsCardDatabase")
        st.success(f"✅ Found {len(cards)} cards from SportsCardDatabase!")
        
        # Show sample of what was found
        if len(cards) > 0:
            sample = cards[0]
            print(f"📋 Sample card: {sample.get('year', '')} {sample.get('set', '')} #{sample.get('card_number', '')} {sample.get('name', '')}")
        
        return cards, len(cards), len(cards), "SportsCardDatabase.com"
        
    except Exception as e:
        error_msg = f"SportsCardDatabase Error: {str(e)}"
        print(error_msg)
        st.error(f"❌ SportsCardDatabase Error: {str(e)}")
        return [], 0, 0, error_msg


def find_player_id(player_name: str) -> Optional[str]:
    """Find player ID by searching player list"""
    try:
        base_url = "http://www.sportscarddatabase.com"
        
        # Clean up player name and extract possible search terms
        search_names = []
        
        # Original name
        search_names.append(player_name.strip())
        
        # Remove suffixes like Jr, Sr, II, III
        clean_name = re.sub(r'\s+(Jr|Sr|II|III|IV)\.?$', '', player_name.strip(), flags=re.IGNORECASE)
        search_names.append(clean_name)
        
        # Split into parts and try different combinations
        name_parts = player_name.strip().split()
        if len(name_parts) >= 2:
            # Last name only
            search_names.append(name_parts[-1])
            # First + Last (no suffix)
            search_names.append(f"{name_parts[0]} {name_parts[-1]}")
        
        # Remove duplicates
        search_names = list(set(search_names))
        
        print(f"🔍 Searching for player using names: {search_names}")
        
        # Try each name variation
        for search_name in search_names:
            # Get first letter of last name for this search
            names = search_name.strip().split()
            if len(names) == 0:
                continue
            
            last_name = names[-1]
            first_letter = last_name[0].upper()
            
            # Search player list for that letter
            player_list_url = f"{base_url}/CardPlayerList.aspx?sp=1&l={first_letter}"
            
            print(f"🔍 Searching player list: {player_list_url} for '{search_name}'")
            response = requests.get(player_list_url, timeout=30)
            response.raise_for_status()
            
            soup = BeautifulSoup(response.text, 'html.parser')
            
            # Look for player links
            player_links = soup.find_all('a', href=re.compile(r'CardPlayer\.aspx\?pid=\d+'))
            
            for link in player_links:
                link_text = link.get_text(strip=True)
                
                # More flexible matching
                search_lower = search_name.lower()
                link_lower = link_text.lower()
                
                # Check for exact match or partial match
                if (search_lower == link_lower or 
                    search_lower in link_lower or 
                    link_lower in search_lower or
                    # Handle cases like "Ken Griffey" matching "Ken Griffey Jr"
                    (search_lower.replace(' jr', '') == link_lower.replace(' jr', '')) or
                    (search_lower.replace(' sr', '') == link_lower.replace(' sr', ''))):
                    
                    # Extract player ID from href
                    href = link.get('href', '')
                    match = re.search(r'pid=(\d+)', href)
                    if match:
                        player_id = match.group(1)
                        print(f"👤 Found player: {link_text} (ID: {player_id}) - matched with '{search_name}'")
                        return player_id
            
            print(f"❌ No match found for '{search_name}' in letter {first_letter}")
        
        print(f"❌ Player '{player_name}' not found after trying all variations")
        return None
        
    except Exception as e:
        print(f"❌ Error finding player ID: {e}")
        return None


def get_player_cards(player_id: str, player_name: str, year: str = "", set_name: str = "", card_number: str = "") -> List[Dict]:
    """Get all cards for a player, with optional filtering"""
    try:
        base_url = "http://www.sportscarddatabase.com"
        cards = []
        page = 1
        
        while True:
            # Get player cards page
            player_url = f"{base_url}/CardPlayer.aspx?pid={player_id}&p={page}&view=1"
            
            print(f"📄 Getting page {page}: {player_url}")
            response = requests.get(player_url, timeout=30)
            response.raise_for_status()
            
            soup = BeautifulSoup(response.text, 'html.parser')
            
            # Find card links
            card_links = soup.find_all('a', href=re.compile(r'CardItem\.aspx\?id=\d+'))
            
            if not card_links:
                # No more cards found
                break
            
            page_cards = []
            for link in card_links:
                try:
                    card_title = link.get_text(strip=True)
                    href = link.get('href', '')
                    
                    # Extract card ID
                    match = re.search(r'id=(\d+)', href)
                    if not match:
                        continue
                    
                    card_id = match.group(1)
                    
                    # Parse card information from title
                    card_info = parse_sportscard_title(card_title, player_name)
                    
                    # Apply filters
                    if year and year not in card_info.get("year", ""):
                        continue
                    if set_name:
                        card_set = card_info.get("set_name", "").lower()
                        filter_set = set_name.lower()
                        # More flexible set matching - partial matches allowed
                        if not (filter_set in card_set or card_set in filter_set):
                            continue
                    if card_number and card_number not in card_info.get("card_number", ""):
                        continue
                    
                    # Get detailed card information
                    card_detail = get_card_details(card_id, card_info)
                    if card_detail:
                        page_cards.append(card_detail)
                        
                except Exception as e:
                    print(f"⚠️ Error processing card: {e}")
                    continue
            
            if not page_cards:
                # No cards on this page match our filters
                break
                
            cards.extend(page_cards)
            print(f"📄 Page {page}: Found {len(page_cards)} matching cards")
            
            # Check if there's a next page
            next_link = soup.find('a', string=re.compile(r'Next', re.IGNORECASE))
            if not next_link:
                break
                
            page += 1
            # Be respectful - add delay between requests
            time.sleep(0.5)
            
            # Safety limit - don't fetch too many pages
            if page > 50:
                print("⚠️ Reached page limit, stopping")
                break
        
        return cards
        
    except Exception as e:
        print(f"❌ Error getting player cards: {e}")
        return []


def parse_sportscard_title(title: str, player_name: str) -> Dict:
    """Parse card information from SportsCardDatabase title"""
    # Example: "1954 Topps #128 Hank Aaron"
    # Example: "1955 Topps Double Header #105-106 Hank Aaron/ Ray Herbert"
    
    card_info = {
        "player_name": player_name,
        "year": "",
        "set_name": "",
        "card_number": "",
        "variety": "Base"
    }
    
    # Extract year (4 digits at start)
    year_match = re.match(r'^(\d{4})', title)
    if year_match:
        card_info["year"] = year_match.group(1)
    
    # Extract card number (# followed by digits)
    number_match = re.search(r'#(\d+(?:-\d+)?)', title)
    if number_match:
        card_info["card_number"] = number_match.group(1)
    
    # Extract set name (between year and card number)
    set_pattern = r'\d{4}\s+(.+?)\s+#'
    set_match = re.search(set_pattern, title)
    if set_match:
        card_info["set_name"] = set_match.group(1).strip()
    
    # Detect special varieties
    title_lower = title.lower()
    if any(word in title_lower for word in ['rookie', 'rc']):
        card_info["variety"] = "Rookie"
    elif any(word in title_lower for word in ['refractor', 'ref']):
        card_info["variety"] = "Refractor"
    elif 'autograph' in title_lower or 'auto' in title_lower:
        card_info["variety"] = "Autograph"
    elif 'relic' in title_lower:
        card_info["variety"] = "Relic"
    elif 'parallel' in title_lower:
        card_info["variety"] = "Parallel"
    
    return card_info


def get_card_details(card_id: str, card_info: Dict) -> Optional[Dict]:
    """Get detailed information for a specific card"""
    try:
        base_url = "http://www.sportscarddatabase.com"
        card_url = f"{base_url}/CardItem.aspx?id={card_id}"
        
        response = requests.get(card_url, timeout=30)
        response.raise_for_status()
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Extract player name from card_info
        player_name = card_info.get("player_name", "")
        year = card_info.get("year", "")
        set_name = card_info.get("set_name", "")
        card_number = card_info.get("card_number", "")
        
        # Try to get real card images from multiple sources
        image_url = find_baseball_card_image(player_name, year, set_name, card_number)
        
        # If no image found, use placeholder
        if not image_url:
            image_url = generate_baseball_card_image(card_info)
        
        # Create card data in our standard format
        card_data = {
            "name": player_name,
            "set": card_info.get("set_name", "Unknown Set"),
            "year": card_info.get("year", ""),
            "team": "",  # Would need additional parsing
            "card_number": card_info.get("card_number", ""),
            "position": "",  # Would need additional parsing
            "variety": card_info.get("variety", "Base"),
            "price_usd": 0.0,  # SportsCardDatabase doesn't show pricing directly
            "image_url": image_url,
            "link": card_url,
            "game": "Baseball Cards",
            "quantity": 1,
            "variant": "",
            "source": "SportsCardDatabase.com"
        }
        
        return card_data
        
    except Exception as e:
        print(f"⚠️ Error getting card details for {card_id}: {e}")
        return None


def generate_baseball_card_image(card_info: Dict) -> str:
    """Generate a placeholder image URL for baseball cards"""
    try:
        # Extract card information for the placeholder
        player_name = card_info.get("player_name", "Baseball Card")
        year = card_info.get("year", "")
        set_name = card_info.get("set_name", "")
        card_number = card_info.get("card_number", "")
        variety = card_info.get("variety", "Base")
        
        # Use picsum.photos with seed for consistent images - more reliable than placeholder.com
        # Create a unique seed based on card info
        seed = f"{player_name}{year}{set_name}{card_number}".replace(" ", "_")
        encoded_seed = urllib.parse.quote(seed)
        
        # Choose a parameter based on variety for different looking cards
        variety_params = {
            "Base": "blur",      # Blurred gradient
            "Rookie": "grayscale", # Grayscale
            "Refractor": "sepia",   # Sepia tone
            "Autograph": "random",  # Random
            "Relic": "random",      # Random
            "Parallel": "random"    # Random
        }
        param = variety_params.get(variety, "blur")
        
        # Generate placeholder image URL using picsum.photos
        placeholder_url = f"https://picsum.photos/seed/{encoded_seed}/300/420?{param}"
        
        print(f"🖼️ Generated placeholder image: {placeholder_url}")
        return placeholder_url
        
    except Exception as e:
        print(f"⚠️ Error generating placeholder image: {e}")
        # Return a simple local fallback - use a data URI for a basic colored rectangle
        return "data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMzAwIiBoZWlnaHQ9IjQyMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cmVjdCB3aWR0aD0iMzAwIiBoZWlnaHQ9IjQyMCIgZmlsbD0iIzQxNjlFMSIvPjx0ZXh0IHg9IjUwJSIgeT0iNTAlIiBmb250LXNpemU9IjE4IiBmaWxsPSIjRkZGRkZGIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBkeT0iLjNlbSI+QmFzZWJhbGwgQ2FyZDwvdGV4dD48L3N2Zz4="


def search_sportscardspro(player_name: str, year: str = "", set_name: str = "", card_number: str = "") -> Tuple[List[Dict], int, int, str]:
    """Search SportCardsPro.com for baseball cards"""
    try:
        base_url = "https://www.sportscardspro.com"
        
        print(f"🔍 Searching SportCardsPro for: {player_name}")
        st.info("🔍 Searching SportCardsPro.com...")
        
        # Try to construct direct set URL first
        if year and set_name:
            # Convert set name to URL format
            set_url_name = set_name.lower().replace(' ', '-').replace('.', '')
            set_url = f"{base_url}/console/baseball-cards-{year}-{set_url_name}"
            
            print(f"🔍 Trying set URL: {set_url}")
            
            try:
                response = requests.get(set_url, timeout=30)
                if response.status_code == 200:
                    soup = BeautifulSoup(response.text, 'html.parser')
                    
                    # Look for player cards in the set
                    card_links = soup.find_all('a', href=re.compile(r'/card/'))
                    cards = []
                    
                    for link in card_links:
                        link_text = link.get_text(strip=True).lower()
                        if player_name.lower() in link_text:
                            # Parse card information from link text
                            card_info = parse_sportscardspro_title(link_text, player_name)
                            
                            # Apply filters
                            if year and year not in card_info.get("year", ""):
                                continue
                            if set_name and set_name.lower() not in card_info.get("set_name", "").lower():
                                continue
                            if card_number and card_number not in card_info.get("card_number", ""):
                                continue
                            
                            # Get detailed card information
                            card_detail = get_sportscardspro_card_details(base_url + link.get('href', ''), card_info)
                            if card_detail:
                                cards.append(card_detail)
                    
                    if cards:
                        print(f"✅ Found {len(cards)} cards from SportCardsPro set page")
                        st.success(f"✅ Found {len(cards)} cards from SportCardsPro!")
                        return cards, len(cards), len(cards), "SportCardsPro.com"
            
            except Exception as e:
                print(f"⚠️ Error accessing set page: {e}")
        
        # Fallback to general search
        search_query = f"{player_name} {year} {set_name}".replace(' ', '+')
        search_url = f"{base_url}/search?q={search_query}"
        
        print(f"🔍 General search: {search_url}")
        
        response = requests.get(search_url, timeout=30)
        response.raise_for_status()
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Look for card links in search results
        card_links = soup.find_all('a', href=re.compile(r'/card/'))
        cards = []
        
        for link in card_links:
            link_text = link.get_text(strip=True).lower()
            if player_name.lower() in link_text:
                # Parse card information
                card_info = parse_sportscardspro_title(link_text, player_name)
                
                # Apply filters
                if year and year not in card_info.get("year", ""):
                    continue
                if set_name and set_name.lower() not in card_info.get("set_name", "").lower():
                    continue
                if card_number and card_number not in card_info.get("card_number", ""):
                    continue
                
                # Get detailed card information
                card_detail = get_sportscardspro_card_details(base_url + link.get('href', ''), card_info)
                if card_detail:
                    cards.append(card_detail)
        
        if not cards:
            print("❌ No cards found on SportCardsPro")
            st.warning("❌ No cards found on SportCardsPro")
            return [], 0, 0, "No cards found"
        
        print(f"✅ Found {len(cards)} cards from SportCardsPro search")
        st.success(f"✅ Found {len(cards)} cards from SportCardsPro!")
        
        return cards, len(cards), len(cards), "SportCardsPro.com"
        
    except Exception as e:
        error_msg = f"SportCardsPro Error: {str(e)}"
        print(error_msg)
        st.error(f"❌ SportCardsPro Error: {str(e)}")
        return [], 0, 0, error_msg


def parse_sportscardspro_title(title: str, player_name: str) -> Dict:
    """Parse card information from SportCardsPro title"""
    card_info = {
        "player_name": player_name,
        "year": "",
        "set_name": "",
        "card_number": "",
        "variety": "Base"
    }
    
    # Extract year (4 digits)
    year_match = re.search(r'(\d{4})', title)
    if year_match:
        card_info["year"] = year_match.group(1)
    
    # Extract card number (# followed by digits)
    number_match = re.search(r'#(\d+)', title)
    if number_match:
        card_info["card_number"] = number_match.group(1)
    
    # Extract set name (between year and card number)
    set_pattern = r'\d{4}\s+(.+?)\s+#'
    set_match = re.search(set_pattern, title)
    if set_match:
        card_info["set_name"] = set_match.group(1).strip()
    
    return card_info


def get_sportscardspro_card_details(card_url: str, card_info: Dict) -> Optional[Dict]:
    """Get detailed information for a specific SportCardsPro card"""
    try:
        response = requests.get(card_url, timeout=30)
        response.raise_for_status()
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Try to find card image
        image_url = ""
        img_tags = soup.find_all('img')
        for img in img_tags:
            src = img.get('src', '')
            if 'card' in src.lower() or 'image' in src.lower():
                if src.startswith('/'):
                    src = "https://www.sportscardspro.com" + src
                image_url = src
                break
        
        # If no image found, use placeholder
        if not image_url:
            image_url = generate_baseball_card_image(card_info)
        
        # Create card data in our standard format
        card_data = {
            "name": card_info.get("player_name", ""),
            "set": card_info.get("set_name", "Unknown Set"),
            "year": card_info.get("year", ""),
            "team": "",  # Would need additional parsing
            "card_number": card_info.get("card_number", ""),
            "position": "",  # Would need additional parsing
            "variety": card_info.get("variety", "Base"),
            "price_usd": 0.0,  # SportCardsPro pricing would need additional parsing
            "image_url": image_url,
            "link": card_url,
            "game": "Baseball Cards",
            "quantity": 1,
            "variant": "",
            "source": "SportCardsPro.com"
        }
        
        return card_data
        
    except Exception as e:
        print(f"⚠️ Error getting SportCardsPro card details: {e}")
        return None


# Baseball Card Search Functions
def baseball_search_ebay(player_name: str, year: str = "", team: str = "", set_name: str = "", card_number: str = "") -> Tuple[List[Dict], int, int, str]:
    """Search eBay for baseball cards"""
    try:
        # Check which eBay environment to use
        ebay_env = st.session_state.get("last_ebay_env", "Sandbox")
        
        if ebay_env == "Production":
            ebay_app_id = get_secret("EBAY_APP_ID")
            base_url = "https://svcs.ebay.com/services/search/FindingService/v1"
            print("🚀 Using eBay Production API")
        else:
            ebay_app_id = get_secret("EBAY_APP_ID_SBX")
            base_url = "https://svcs.sandbox.ebay.com/services/search/FindingService/v1"
            print("🧪 Using eBay Sandbox API")
        
        if not ebay_app_id:
            st.error(f"❌ eBay API key not configured for {ebay_env} environment")
            print(f"❌ eBay API key not configured for {ebay_env}")
            return [], 0, 0, f"eBay API key not configured for {ebay_env}"
        
        print(f"🔑 eBay App ID: {ebay_app_id[:15]}... ({ebay_env})")
        
        # Build search query
        query_parts = [player_name.strip()]
        if year:
            query_parts.append(year)
        if team:
            query_parts.append(team)
        if set_name:
            query_parts.append(set_name)
        if card_number:
            query_parts.append(f"#{card_number}")
        
        query = " ".join(query_parts) + " baseball card"
        print(f"🔍 Search query: {query}")
        
        # API parameters
        params = {
            "OPERATION-NAME": "findItemsAdvanced",
            "SERVICE-VERSION": "1.0.0",
            "SECURITY-APPNAME": ebay_app_id,
            "RESPONSE-DATA-FORMAT": "JSON",
            "REST-PAYLOAD": "",
            "keywords": query,
            "categoryId": "212",  # Baseball cards
            "itemFilter(0).name": "Condition",
            "itemFilter(0).value": "New",
            "itemFilter(1).name": "ListingType",
            "itemFilter(1).value": "AuctionWithBIN",
            "sortOrder": "BestMatch",
            "paginationInput.entriesPerPage": "50"
        }
        
        print(f"🌐 Making request to: {base_url}")
        print(f"📋 Request params: {params}")
        
        response = requests.get(base_url, params=params, timeout=30)
        
        print(f"📊 Response status: {response.status_code}")
        print(f"📦 Response content length: {len(response.content)} bytes")
        
        # Check HTTP status codes
        if response.status_code == 401 or response.status_code == 403:
            print("🧪 eBay authentication failed - using mock data")
            st.warning("🧪 eBay authentication failed - using mock data")
            return create_mock_baseball_cards(player_name, year, team, set_name, card_number, f"eBay {ebay_env} - Authentication failed")
        
        response.raise_for_status()
        data = response.json()
        
        print(f"📄 Response data keys: {list(data.keys())}")
        
        # Parse response for errors
        find_response = data.get("findItemsAdvancedResponse", [{}])[0]
        errors = find_response.get("errors", [])
        
        if errors and isinstance(errors, list) and len(errors) > 0:
            error_info = errors[0]
            error_id = error_info.get("errorId", [])
            message = error_info.get("message", [])
            
            print(f"❌ eBay Error ID: {error_id}")
            print(f"❌ eBay Error Message: {message}")
            st.error(f"❌ eBay Error: {message}")
            
            if (isinstance(error_id, list) and "11002" in error_id) or \
               (isinstance(message, list) and any("Invalid Application" in str(msg) for msg in message)):
                print("🧪 eBay Sandbox App ID not registered - using mock data")
                st.warning("🧪 eBay Sandbox App ID not registered - using mock data")
                return create_mock_baseball_cards(player_name, year, team, set_name, card_number, f"eBay {ebay_env} - App ID not registered")
        
        # Parse results
        search_result = find_response.get("searchResult", [{}])[0].get("item", [])
        print(f"🎯 Found {len(search_result)} items in search results")
        st.write(f"🎯 Found `{len(search_result)}` items in search results")
        
        if len(search_result) == 0:
            st.warning(f"🔍 No items found in eBay {ebay_env.lower()}. This is normal for sandbox - limited test data.")
            st.info("💡 Using mock data for demonstration purposes.")
            cards = create_mock_baseball_cards(player_name, year, team, set_name, card_number)
            return cards, len(cards), len(cards), f"eBay {ebay_env} (Mock Data)"
        
        # Process real results
        cards = []
        for item in search_result:
            try:
                # Extract item details
                title = item.get("title", [{}])[0]
                item_id = item.get("itemId", [{}])[0]
                gallery_url = item.get("galleryURL", [{}])[0]
                view_item_url = item.get("viewItemURL", [{}])[0]
                
                # Parse card info from title
                card_info = parse_ebay_baseball_title(title)
                
                # Create card data
                card_data = {
                    "name": player_name,
                    "set": card_info.get("set", "Unknown Set"),
                    "year": card_info.get("year", ""),
                    "team": card_info.get("team", ""),
                    "card_number": card_info.get("card_number", ""),
                    "position": "",
                    "variety": card_info.get("variety", "Base"),
                    "price_usd": 0.0,
                    "image_url": gallery_url,
                    "link": view_item_url,
                    "game": "Baseball Cards",
                    "quantity": 1,
                    "variant": "",
                    "source": f"eBay {ebay_env}"
                }
                cards.append(card_data)
                
            except Exception as e:
                print(f"⚠️ Error processing eBay item: {e}")
                continue
        
        print(f"✅ Successfully processed {len(cards)} cards from eBay {ebay_env}")
        return cards, len(cards), len(cards), f"eBay {ebay_env}"
        
    except Exception as e:
        error_msg = f"eBay {ebay_env} Error: {str(e)}"
        print(error_msg)
        st.error(f"❌ {error_msg}")
        return [], 0, 0, error_msg


def parse_ebay_baseball_title(title: str) -> Dict:
    """Parse eBay baseball card title for card information"""
    card_info = {
        "year": "",
        "set": "",
        "team": "",
        "card_number": "",
        "variety": "Base"
    }
    
    # Extract year (4 digits)
    year_match = re.search(r'(\d{4})', title)
    if year_match:
        card_info["year"] = year_match.group(1)
    
    # Extract card number
    number_match = re.search(r'#(\d+)', title)
    if number_match:
        card_info["card_number"] = number_match.group(1)
    
    # Extract variety
    varieties = ["Rookie", "Refractor", "Autograph", "Relic", "Parallel", "Chrome", "Gold", "Silver"]
    for variety in varieties:
        if variety.lower() in title.lower():
            card_info["variety"] = variety
            break
    
    return card_info


def create_mock_baseball_cards(player_name: str, year: str = "", team: str = "", set_name: str = "", card_number: str = "", source: str = "Mock Data") -> List[Dict]:
    """Create mock baseball cards for testing when no real data is available"""
    cards = []
    
    # Default sets if none provided
    if not set_name:
        if year:
            set_name = f"{year} Topps"
        else:
            set_name = "2023 Topps"
    
    # Create 3 mock cards with different varieties
    varieties = ["Base", "Rookie", "Refractor"]
    colors = ["4169E1", "FFD700", "FF6347"]  # Blue, Gold, Red
    
    for i, (variety, color) in enumerate(zip(varieties, colors)):
        card = {
            "name": player_name,
            "set": set_name,
            "year": year or "2023",
            "team": team or "Unknown Team",
            "card_number": card_number or str(i + 1),
            "position": "Fielder",
            "variety": variety,
            "price_usd": round(10.0 + (i * 5.0), 2),  # Mock prices
            "image_url": f"https://via.placeholder.com/300x420/{color}/FFFFFF?text={variety.replace(' ', '+')}",
            "link": f"https://example.com/card/{i+1}",
            "game": "Baseball Cards",
            "quantity": 1,
            "variant": "",
            "source": source
        }
        cards.append(card)
    
    print(f"🧪 Created {len(cards)} mock baseball cards")
    return cards


