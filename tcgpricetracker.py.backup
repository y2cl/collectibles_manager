def main():
    st.set_page_config(page_title="Collections Tracker", page_icon="💳", layout="wide")
    
    # Only show header on main page (not on dedicated pages)
    if not any(st.session_state.get(key) for key in [SESSION_KEYS["show_collection_view"], SESSION_KEYS["show_sets_view"], SESSION_KEYS["show_mtg_sets_view"]]):
        st.title("Collections Tracker")
        st.caption("Search Magic: The Gathering (Scryfall) and Pokémon (Pokémon TCG API) card prices, plus eBay sold comps.")

    # Secrets / keys
    pokemon_api_key = get_secret("POKEMONTCG_API_KEY")
    justtcg_api_key = get_secret("JUSTTCG_API_KEY")
    ebay_app_id = get_secret("EBAY_APP_ID")
    
    # Create wrapper function for Pokemon sets update with API key
    def pokemontcg_get_sets_with_key():
        return pokemontcg_get_sets(api_key=pokemon_api_key)
    
    # Load toggle settings from JSON file
    toggle_settings = load_toggle_settings()
    
    # Clean up old widget keys that might be causing conflicts
    old_widget_keys = ['pokemon_enabled_widget', 'justtcg_enabled_widget', 'public_enabled_widget', 'fallback_enabled_widget']
    for key in old_widget_keys:
        if key in st.session_state:
            del st.session_state[key]
    
    # Initialize in-memory mirror of collection (optional UI use)
    if SESSION_KEYS["collection"] not in st.session_state:
        st.session_state[SESSION_KEYS["collection"]] = []

    # Search form
    # Only show search form on main page (not on dedicated pages)
    is_main_page = not any(st.session_state.get(key) for key in [SESSION_KEYS["show_collection_view"], SESSION_KEYS["show_sets_view"], SESSION_KEYS["show_mtg_sets_view"]])
    
    if is_main_page:
        col1, col2 = st.columns([2, 1])
        with col1:
            # Collection selector outside form to trigger re-render
            current_game = st.session_state.get("selected_game", "Pokémon")
            game = st.selectbox("Collection", list(GAMES.values()), index=list(GAMES.values()).index(current_game))
            
            # Update session state when game changes and trigger re-run
            if game != current_game:
                st.session_state["selected_game"] = game
                # Clear previous search to avoid confusion
                if SESSION_KEYS["last_query"] in st.session_state:
                    del st.session_state[SESSION_KEYS["last_query"]]
                st.rerun()
            
            with st.form("search_form"):
                # Dynamic form fields based on game type
                if game == "Baseball Cards":
                    # Baseball Cards specific fields
                    st.subheader("⚾ Baseball Card Search")
                    col1, col2 = st.columns(2)
                    with col1:
                        player_name = st.text_input("Player Name*", placeholder="e.g., Ken Griffey Jr.", key="baseball_player")
                        year = st.text_input("Year", placeholder="e.g., 2023", key="baseball_year")
                    with col2:
                        set_name = st.text_input("Set/Brand", placeholder="e.g., Topps, Bowman", key="baseball_set")
                        card_number = st.text_input("Card Number", placeholder="e.g., 100", key="baseball_number")
                    
                elif game == "Pokémon":
                    # Pokémon specific fields
                    st.subheader("🃏 Pokémon Card Search")
                    col1, col2 = st.columns(2)
                    with col1:
                        card_name = st.text_input("Card Name*", placeholder="e.g., Charizard", key="pokemon_name")
                    with col2:
                        set_name = st.text_input("Set (optional)", placeholder="e.g., Base Set", key="pokemon_set")
                    
                    # Pokemon specific fields
                    pokemon_row = st.columns(2)
                    with pokemon_row[0]:
                        set_number = st.text_input("Set Number (optional)", placeholder="e.g., 4/102", key="pokemon_number")
                    with pokemon_row[1]:
                        # Add Pokemon specific fields if needed
                        pass
                
                else:  # Magic: The Gathering
                    # MTG specific fields
                    st.subheader("🧙 Magic: The Gathering Card Search")
                    col1, col2 = st.columns(2)
                    with col1:
                        card_name = st.text_input("Card Name*", placeholder="e.g., Black Lotus", key="mtg_name")
                    with col2:
                        set_name = st.text_input("Set (optional)", placeholder="e.g., Alpha, Beta", key="mtg_set")
                    
                    # MTG specific fields
                    mtg_row = st.columns(2)
                    with mtg_row[0]:
                        set_number = st.text_input("Card Number (optional)", placeholder="e.g., 1", key="mtg_number")
                    with mtg_row[1]:
                        # Add MTG specific fields if needed
                        pass
                
                submitted = st.form_submit_button("Search")
                if submitted:
                    # Build query data based on game type
                    query_data = {"game": game}
                    
                    if game == "Baseball Cards":
                        if not player_name.strip():
                            st.error("Player Name is required for Baseball Cards")
                            st.stop()
                        query_data.update({
                            "card_name": player_name,
                            "set_name": set_name,
                            "set_number": card_number,
                            "year": year
                        })
                    else:  # Pokémon or MTG
                        if not card_name.strip():
                            st.error("Card Name is required")
                            st.stop()
                        query_data.update({
                            "card_name": card_name,
                            "set_name": set_name,
                            "set_number": set_number if 'set_number' in locals() else ""
                        })
                    
                    st.session_state[SESSION_KEYS["last_query"]] = query_data
                    st.rerun()

    with st.sidebar:
        # Home button at the top
        if st.button("🏠 Home", key="home_button", use_container_width=True):
            # Clear all session states to return to home
            for key in SESSION_KEYS.values():
                if key in st.session_state:
                    del st.session_state[key]
            st.rerun()
        
        st.header("Display")
        with st.expander("Display Options", expanded=False):
            view_mode = st.radio("View mode", options=VIEW_MODES, index=0, horizontal=True)
            cards_per_row = st.slider("Cards per row (grid)", min_value=2, max_value=5, value=DEFAULT_CARDS_PER_ROW)
            image_width = st.slider("Image width (px)", min_value=160, max_value=400, value=CARD_IMAGE_WIDTH, step=10)
            compact_mode = st.toggle("Compact mode", value=False)
            # Default Pokémon to quick mode for faster responses
            last_query = st.session_state.get(SESSION_KEYS["last_query"], {})
            quick_mode_default = last_query.get("game") == "Pokémon"
            quick_mode_pkmn = st.toggle("Quick mode (Pokémon)", value=quick_mode_default)
            per_page = st.selectbox("Results per page", options=RESULTS_PER_PAGE_OPTIONS, index=0)
            sort_option = st.selectbox(
                "Sort",
                options=[
                    "Relevance",
                    "Price ↑",
                    "Price ↓",
                    "Release year ↑",
                    "Release year ↓",
                ],
                index=0,
            )
        
        st.header("Filters")
        with st.expander("Filters", expanded=False):
            rarity_filter = st.text_input("Rarity contains", value="")
            year_min, year_max = st.slider("Release year range", min_value=1993, max_value=datetime.now().year, value=(1993, datetime.now().year))
            type_filter = st.text_input("Type contains (e.g., Creature, Stage 2)", value="")
            price_min = st.number_input("Min price", min_value=0.0, value=0.0, step=0.5)
            price_max = st.number_input("Max price (0 = no max)", min_value=0.0, value=0.0, step=0.5)
        st.divider()
        st.header("Collection")
        df = load_collection_dataframe()
        total_rows = len(df)
        total_qty = int(df["quantity"].sum()) if (not df.empty and "quantity" in df.columns) else 0
        st.write(f"Items: {total_rows} | Total qty: {total_qty}")
        
        # Collection management button
        if st.button("📚 Manage Collection", key="open_collection_page", use_container_width=True):
            st.session_state[SESSION_KEYS["show_collection_view"]] = True
            st.session_state[SESSION_KEYS["show_sets_view"]] = False
            st.session_state[SESSION_KEYS["show_mtg_sets_view"]] = False
            st.rerun()
        
        st.divider()
        st.header("Tools")
        col1, col2 = st.columns(2)
        with col1:
            if st.button("⚡ Pokémon Sets", key="open_sets_page"):
                st.session_state[SESSION_KEYS["show_sets_view"]] = True
                st.session_state[SESSION_KEYS["show_collection_view"]] = False
                st.session_state[SESSION_KEYS["show_mtg_sets_view"]] = False
                st.rerun()
        with col2:
            if st.button("🃏 MTG Sets", key="open_mtg_sets_page"):
                st.session_state[SESSION_KEYS["show_mtg_sets_view"]] = True
                st.session_state[SESSION_KEYS["show_collection_view"]] = False
                st.session_state[SESSION_KEYS["show_sets_view"]] = False
                st.rerun()
        
        st.divider()
        st.header("Settings")
        
        # Fallback Data Statistics
        with st.expander("📁 Fallback Data Stats", expanded=False):
            stats = get_fallback_stats()
            st.write("**Pokémon Data:**")
            col1, col2 = st.columns(2)
            col1.metric("Sets", stats["pokemon_sets"])
            col2.metric("Cards", stats["pokemon_cards"])
            col1, col2 = st.columns(2)
            col1.metric("Set Images", stats["pokemon_set_images"])
            col2.metric("Card Images", stats["pokemon_card_images"])
            
            st.write("**MTG Data:**")
            col1, col2 = st.columns(2)
            col1.metric("Sets", stats["mtg_sets"])
            col2.metric("Cards", stats["mtg_cards"])
            col1, col2 = st.columns(2)
            col1.metric("Set Images", stats["mtg_set_images"])
            col2.metric("Card Images", stats["mtg_card_images"])
        
        with st.expander("API Configuration", expanded=False):
            st.subheader("🔑 API Key Management")
            st.write("Configure your API keys for different TCG data sources.")
            
            # Pokémon TCG API Key
            st.divider()
            st.write("**🎴 Pokémon TCG API**")
            pokemon_key_input = st.text_input(
                "Pokémon TCG API Key",
                type="password",
                value=get_secret("POKEMONTCG_API_KEY") or "",
                help="Get your API key from https://pokemontcg.io/",
                key="pokemon_api_key_input"
            )
            if st.button("💾 Save Pokémon API Key", key="save_pokemon_key"):
                if pokemon_key_input.strip():
                    # Note: In a real app, you'd save this to secrets.toml or a secure storage
                    st.success("✅ Pokémon TCG API key would be saved")
                    st.info("💡 In production, this would be securely stored in .streamlit/secrets.toml")
                else:
                    st.error("❌ Please enter a valid API key")
            
            # JustTCG API Key
            st.write("**🌐 JustTCG API**")
            justtcg_key_input = st.text_input(
                "JustTCG API Key",
                type="password",
                value=get_secret("JUSTTCG_API_KEY") or "",
                help="Get your API key from https://justtcg.com/",
                key="justtcg_api_key_input"
            )
            if st.button("💾 Save JustTCG API Key", key="save_justtcg_key"):
                if justtcg_key_input.strip():
                    st.success("✅ JustTCG API key would be saved")
                    st.info("💡 In production, this would be securely stored in .streamlit/secrets.toml")
                else:
                    st.error("❌ Please enter a valid API key")
            
            # eBay App ID
            st.write("**🛒 eBay API**")
            ebay_key_input = st.text_input(
                "eBay App ID",
                type="password",
                value=get_secret("EBAY_APP_ID") or "",
                help="Get your App ID from eBay Developers Program",
                key="ebay_api_key_input"
            )
            if st.button("💾 Save eBay App ID", key="save_ebay_key"):
                if ebay_key_input.strip():
                    st.success("✅ eBay App ID would be saved")
                    st.info("💡 In production, this would be securely stored in .streamlit/secrets.toml")
                else:
                    st.error("❌ Please enter a valid App ID")
            
            st.divider()
            st.info("""
            **📝 How to add API keys permanently:**
            
            Edit `.streamlit/secrets.toml` and add:
            ```toml
            POKEMONTCG_API_KEY = "your_key_here"
            JUSTTCG_API_KEY = "your_key_here"
            EBAY_APP_ID = "your_app_id_here"
            ```
            
            Then restart the app for changes to take effect.
            """)
        
        with st.expander("API Sources", expanded=False):
            st.subheader("Magic: The Gathering")
            st.write("🔗 **Scryfall API** (Free)")
            scryfall_enabled = st.toggle("Enable Scryfall", value=st.session_state.get("scryfall_enabled", True), key="scryfall_enabled")
            st.caption("Official MTG card database - always free")
            
            st.divider()
            st.subheader("Pokémon TCG")
            st.write("🔑 **Pokémon TCG API** (Requires API Key)")
            pokemon_enabled = st.toggle("Enable Pokémon TCG API", value=toggle_settings["pokemon_enabled"], key="pokemon_enabled")
            # Save to JSON when changed
            if pokemon_enabled != toggle_settings["pokemon_enabled"]:
                update_toggle_setting("pokemon_enabled", pokemon_enabled)
                toggle_settings["pokemon_enabled"] = pokemon_enabled
            # Debug: Immediate toggle state
            if st.session_state.get("debug_mode", False):
                st.write(f"🔍 Pokémon toggle value: {pokemon_enabled} | JSON setting: {toggle_settings['pokemon_enabled']}")
            if pokemon_enabled:
                api_key = get_secret("POKEMONTCG_API_KEY")
                if api_key:
                    st.success("✅ API key configured")
                else:
                    st.error("❌ API key missing in .streamlit/secrets.toml")
                    st.code("POKEMONTCG_API_KEY = 'your_key_here'")
            st.caption("Official Pokémon TCG database - requires API key")
            
            st.write("🌐 **Public Endpoint** (Free)")
            public_enabled = st.toggle("Enable Public Endpoint", value=True, key="public_enabled")
            st.caption("Free public Pokémon data - limited availability")
            
            st.write("💾 **Fallback Data** (Offline)")
            fallback_enabled = st.toggle("Enable Fallback Data", value=True, key="fallback_enabled")
            st.caption("Built-in fallback data when APIs fail")
            
            st.divider()
            st.subheader("Multi-TCG")
            st.write("🔗 **JustTCG API** (Requires API key)")
            justtcg_enabled = st.toggle("Enable JustTCG API", value=toggle_settings["justtcg_enabled"], key="justtcg_enabled")
            # Save to JSON when changed
            if justtcg_enabled != toggle_settings["justtcg_enabled"]:
                update_toggle_setting("justtcg_enabled", justtcg_enabled)
                toggle_settings["justtcg_enabled"] = justtcg_enabled
            # Debug: Immediate toggle state
            if st.session_state.get("debug_mode", False):
                st.write(f"🔍 JustTCG toggle value: {justtcg_enabled} | JSON setting: {toggle_settings['justtcg_enabled']}")
            if justtcg_enabled:
                api_key = get_secret("JUSTTCG_API_KEY")
                if api_key:
                    st.success("✅ API key configured")
                else:
                    st.error("❌ API key missing in .streamlit/secrets.toml")
                    st.code("JUSTTCG_API_KEY = 'your_key_here'")
            st.caption("Multi-TCG pricing database - supports Pokémon, MTG, and more")
            
            st.divider()
            st.subheader("⚾ Baseball Cards")
            st.write("🗃️ **SportsCardDatabase.com** (Free)")
            sportscarddatabase_enabled = st.toggle("Enable SportsCardDatabase", value=st.session_state.get("sportscarddatabase_enabled", True), key="sportscarddatabase_enabled")
            st.caption("Free baseball card database with comprehensive collection and player statistics")
            
            st.write("📊 **SportCardsPro.com** (Free - Temporarily Disabled)")
            sportscardspro_enabled = st.toggle("Enable SportCardsPro", value=False, key="sportscardspro_enabled", disabled=True)
            st.caption("⚠️ Temporarily disabled - site is blocking automated requests")
            
            st.write("🛒 **eBay Baseball Cards** (Requires API Key)")
            ebay_baseball_enabled = st.toggle("Enable eBay Baseball", value=st.session_state.get("ebay_baseball_enabled", True), key="ebay_baseball_enabled")
            if ebay_baseball_enabled:
                # Production vs Sandbox selection
                prod_key = get_secret("EBAY_APP_ID")
                sandbox_key = get_secret("EBAY_APP_ID_SBX")
                
                if prod_key and sandbox_key:
                    st.write("**eBay Environment:**")
                    ebay_env = st.radio(
                        "Choose eBay Environment",
                        ["Production", "Sandbox"],
                        index=1 if "SBX" in str(st.session_state.get("last_ebay_env", "Sandbox")) else 0,
                        key="ebay_environment",
                        help="Production uses real eBay data, Sandbox uses test data"
                    )
                    st.session_state["last_ebay_env"] = ebay_env
                    
                    if ebay_env == "Production":
                        st.success("✅ Production API configured")
                        st.caption("🚀 Using real eBay marketplace data")
                    else:
                        st.info("🧪 Sandbox API configured")
                        st.caption("🧪 Using eBay test environment (mock data)")
                        
                elif prod_key:
                    st.success("✅ Production API key configured")
                    st.caption("🚀 Using real eBay marketplace data")
                    st.session_state["last_ebay_env"] = "Production"
                elif sandbox_key:
                    st.info("🧪 Sandbox API key configured")
                    st.caption("🧪 Using eBay test environment (mock data)")
                    st.session_state["last_ebay_env"] = "Sandbox"
                else:
                    st.error("❌ eBay API key missing in .streamlit/secrets.toml")
                    st.code("EBAY_APP_ID = 'your_production_key_here'")
                    st.code("EBAY_APP_ID_SBX = 'your_sandbox_key_here'")
            st.caption("eBay marketplace for baseball cards with real listings and images")
            
            # Debug: Show current toggle values
            if st.session_state.get("debug_mode", False):
                st.divider()
                st.write("**🔍 Debug - Current Toggle Values:**")
                st.write(f"- Pokémon TCG API: {st.session_state.get('pokemon_enabled', 'NOT SET')}")
                st.write(f"- JustTCG API: {st.session_state.get('justtcg_enabled', 'NOT SET')}")
                st.write(f"- Public Endpoint: {st.session_state.get('public_enabled', 'NOT SET')}")
                st.write(f"- Fallback Data: {st.session_state.get('fallback_enabled', 'NOT SET')}")
                st.write(f"- Scryfall API: {st.session_state.get('scryfall_enabled', 'NOT SET')}")
                st.write(f"- SportsCardDatabase: {st.session_state.get('sportscarddatabase_enabled', 'NOT SET')}")
                st.write(f"- SportCardsPro: {st.session_state.get('sportscardspro_enabled', 'NOT SET')}")
                st.write(f"- eBay Baseball: {st.session_state.get('ebay_baseball_enabled', 'NOT SET')}")
                st.write(f"- eBay Environment: {st.session_state.get('last_ebay_env', 'NOT SET')}")
            
            st.caption("💡 **Tip:** Turn off sources you don't want to use. The app will only try enabled sources in order: Game-specific APIs → Multi-TCG → Public → Fallback")
        
        with st.expander("Debug Options", expanded=False):
            debug_mode = st.toggle("🐛 Debug Mode", value=False, key=SESSION_KEYS["debug_mode"], help="Enable debug output for troubleshooting")
            st.caption("Show detailed search process and API call information")
            
            if debug_mode:
                st.info("🐛 Debug mode is ON - debug messages will appear in search results")
                st.code("Debug info will be logged to: pokemon_search.log")
            else:
                st.success("✅ Debug mode is OFF - clean interface")

    # Inject lightbox once per session for clickable images
    ensure_lightbox()
    # Compact styles if enabled
    if 'compact_mode' in locals() and compact_mode:
        st.markdown(
            """
<style>
.block-container { padding-top: 0.5rem; }
.stMarkdown, .stCaption, .st-emotion-cache, .stText, .stMetric { margin-bottom: 0.25rem !important; }
.stButton>button { padding: 0.35rem 0.6rem; }
</style>
            """,
            unsafe_allow_html=True,
        )

    # One-time confirmation banner if an item was just added
    la = st.session_state.get("last_added")
    if la:
        vtxt = f" — {la.get('variant')}" if (la.get('variant') or '').strip() else ""
        st.success(f"Added {la.get('quantity', 1)}× {la.get('name', '')} ({la.get('set','')}){vtxt} to collection")
        del st.session_state["last_added"]

    # Dedicated MTG Sets page
    if st.session_state.get(SESSION_KEYS["show_mtg_sets_view"]):
        # Load sets from CSV (single source of truth)
        cached_sets = load_sets_from_csv(CACHE_FILES["mtg_sets"])
        
        # Use standardized sets page handler
        render_sets_page(
            sets_data=cached_sets,
            game="mtg",
            cache_file=CACHE_FILES["mtg_sets"],
            update_function=scryfall_get_sets,
            clear_cache_function=lambda f: clear_csv_cache(f)
        )

    # Dedicated Sets page
    if st.session_state.get(SESSION_KEYS["show_sets_view"]):
        # Load sets from CSV (single source of truth) - matching MTG logic
        cached_sets = load_sets_from_csv(CACHE_FILES["pokemon_sets"])
        
        # Use standardized sets page handler
        render_sets_page(
            sets_data=cached_sets,
            game="pokemon",
            cache_file=CACHE_FILES["pokemon_sets"],
            update_function=pokemontcg_get_sets_with_key,
            clear_cache_function=lambda f: clear_csv_cache(f)
        )

    # Dedicated Collection page (check this last)
    if st.session_state.get(SESSION_KEYS["show_collection_view"]):
        # Create tabs for Collection and Watchlist with master filter
        title_col, filter_col = st.columns([3, 1])
        with title_col:
            st.write("## 📚 Collection Management")
        with filter_col:
            master_game_filter = st.selectbox("", ["Select Collection", "Pokémon", "Magic: The Gathering"], key="master_collection_game_filter", label_visibility="collapsed", index=0)
        
        collection_tab, watchlist_tab = st.tabs(["📚 Collection", "⭐ Watchlist"])
        
        with collection_tab:
            
            # Create sub-tabs for better organization
            sub_tab1, sub_tab2, sub_tab3, sub_tab4, sub_tab5 = st.tabs([
                "📊 Dashboard", 
                "🔍 Browse & Filter", 
                "🖼️ Gallery View", 
                "💰 Investment", 
                "🛠️ Management"
            ])
            
            # Load and apply master filter once
            dfc = load_collection_dataframe()
            if not dfc.empty:
                # Apply master game filter (treat "Select Collection" as "All")
                if master_game_filter != "Select Collection":
                    filtered_dfc = dfc[dfc["game"] == master_game_filter].copy()
                else:
                    filtered_dfc = dfc.copy()
                
                # Show filter summary once
                if master_game_filter != "Select Collection":
                    st.info(f"📊 Showing {len(filtered_dfc)} cards ({master_game_filter} only)")
                else:
                    st.info(f"📊 Showing all {len(filtered_dfc)} cards")
                
                # Use filtered data for all tabs
                dfc = filtered_dfc
            
            with sub_tab1:
                st.write("### 📊 Collection Dashboard")
                if dfc.empty:
                    st.info("Your collection is empty. Add cards from the results to get started.")
                else:
                    # Enhanced Analytics Section
                    st.write("#### 📈 Collection Analytics")
                    
                    # Calculate metrics
                    total_rows = len(dfc)
                    total_qty = int(dfc["quantity"].sum()) if ("quantity" in dfc.columns and not dfc.empty) else 0
                    
                    def _row_est(r):
                        try:
                            if r.get("price_mid") and str(r.get("price_mid")) != "nan":
                                return float(r["price_mid"]) * int(r.get("quantity", 1))
                            elif r.get("price_market") and str(r.get("price_market")) != "nan":
                                return float(r["price_market"]) * int(r.get("quantity", 1))
                            elif r.get("price_low") and str(r.get("price_low")) != "nan":
                                return float(r["price_low"]) * int(r.get("quantity", 1))
                            elif r.get("price_usd") and str(r.get("price_usd")) != "nan":
                                return float(r["price_usd"]) * int(r.get("quantity", 1))
                            else:
                                return 0.0
                        except Exception:
                            return 0.0
                    
                    est_total = sum(_row_est(row) for _, row in dfc.iterrows())
                    
                    # Game breakdown
                    pokemon_count = len(dfc[dfc["game"] == "Pokémon"])
                    mtg_count = len(dfc[dfc["game"] == "Magic: The Gathering"])
                    pokemon_value = sum(_row_est(row) for _, row in dfc[dfc["game"] == "Pokémon"].iterrows())
                    mtg_value = sum(_row_est(row) for _, row in dfc[dfc["game"] == "Magic: The Gathering"].iterrows())
                    
                    # Key Metrics Row
                    col1, col2, col3, col4 = st.columns(4)
                    col1.metric("Total Items", f"{total_rows}")
                    col2.metric("Total Qty", f"{total_qty}")
                    col3.metric("Est. Value", f"${est_total:.2f}")
                    col4.metric("Avg Card Value", f"${est_total/total_rows:.2f}" if total_rows > 0 else "$0.00")
                    
                    # Game Breakdown Charts
                    col1, col2 = st.columns(2)
                    
                    with col1:
                        st.write("**📈 Collection by Game (Items)**")
                        if pokemon_count > 0 or mtg_count > 0:
                            import pandas as pd
                            game_data = pd.DataFrame({
                                'Game': ['Pokémon', 'Magic: The Gathering'],
                                'Count': [pokemon_count, mtg_count]
                            })
                            st.bar_chart(game_data.set_index('Game'))
                        else:
                            st.info("No game data available")
                    
                    with col2:
                        st.write("**💰 Collection by Game (Value)**")
                        if pokemon_value > 0 or mtg_value > 0:
                            value_data = pd.DataFrame({
                                'Game': ['Pokémon', 'Magic: The Gathering'],
                                'Value': [pokemon_value, mtg_value]
                            })
                            st.bar_chart(value_data.set_index('Game'))
                        else:
                            st.info("No value data available")
                    
                    # Additional Insights
                    st.write("#### 🎯 Collection Insights")
                    
                    insight_col1, insight_col2, insight_col3 = st.columns(3)
                    
                    with insight_col1:
                        # Most valuable card
                        most_valuable = dfc.loc[dfc.apply(_row_est, axis=1).idxmax()] if total_rows > 0 else None
                        if most_valuable is not None and not most_valuable.empty:
                            card_value = _row_est(most_valuable)
                            st.info(f"💎 **Most Valuable:**\n{most_valuable.get('name', 'Unknown')}\n${card_value:.2f}")
                    
                    with insight_col2:
                        # Average price per game
                        if pokemon_count > 0:
                            avg_pokemon = pokemon_value / pokemon_count
                            st.info(f"⚡ **Pokémon Avg:**\n${avg_pokemon:.2f}")
                        if mtg_count > 0:
                            avg_mtg = mtg_value / mtg_count
                            st.info(f"🃏 **MTG Avg:**\n${avg_mtg:.2f}")
                    
                    with insight_col3:
                        # Collection diversity
                        unique_sets = dfc['set'].nunique() if 'set' in dfc.columns else 0
                        st.info(f"📚 **Unique Sets:**\n{unique_sets}")
                    
                    # Collection Goals & Milestones
                    st.write("#### 🎯 Collection Goals & Milestones")
                    
                    goals_col1, goals_col2 = st.columns(2)
                    
                    with goals_col1:
                        st.write("**📈 Progress Tracking**")
                        
                        # Set completion goals
                        if 'set' in dfc.columns:
                            set_counts = dfc['set'].value_counts()
                            largest_set = set_counts.index[0] if len(set_counts) > 0 else None
                            
                            if largest_set:
                                st.write(f"🏆 Largest Set: {largest_set} ({set_counts.iloc[0]} cards)")
                            
                            # Collection milestones
                            milestones = [
                                (10, "🌟 Starter Collection"),
                                (25, "🎯 Growing Collector"), 
                                (50, "💎 Serious Collector"),
                                (100, "👑 Master Collector"),
                                (250, "🏆 Legendary Collector"),
                                (500, "🌟 Elite Collector")
                            ]
                            
                            current_milestone = None
                            next_milestone = None
                            
                            for count, title in milestones:
                                if total_rows >= count:
                                    current_milestone = (count, title)
                                elif next_milestone is None:
                                    next_milestone = (count, title)
                                    break
                            
                            if current_milestone:
                                st.success(f"✅ {current_milestone[1]} ({current_milestone[0]}+ cards)")
                            
                            if next_milestone:
                                progress = (total_rows / next_milestone[0]) * 100
                                st.write(f"🎯 Next: {next_milestone[1]} ({total_rows}/{next_milestone[0]} cards)")
                                st.progress(progress / 100)
                    
                    with goals_col2:
                        st.write("**🎮 Game-Specific Goals**")
                        
                        # Pokemon goals
                        if pokemon_count > 0:
                            st.write(f"⚡ **Pokémon Collection:** {pokemon_count} cards")
                            pokemon_goal = 100
                            pokemon_progress = min(pokemon_count / pokemon_goal, 1.0)
                            st.progress(pokemon_progress)
                            st.write(f"Goal: {pokemon_goal} cards ({pokemon_progress*100:.1f}%)")
                        
                        # MTG goals  
                        if mtg_count > 0:
                            st.write(f"🃏 **MTG Collection:** {mtg_count} cards")
                            mtg_goal = 100
                            mtg_progress = min(mtg_count / mtg_goal, 1.0)
                            st.progress(mtg_progress)
                            st.write(f"Goal: {mtg_goal} cards ({mtg_progress*100:.1f}%)")
                        
                        # Value goals
                        value_goal = 1000
                        value_progress = min(est_total / value_goal, 1.0)
                        st.write(f"💰 **Collection Value:** ${est_total:.2f}")
                        st.progress(value_progress)
                        st.write(f"Goal: ${value_goal} ({value_progress*100:.1f}%)")
            
            with sub_tab2:
                st.write("### 🔍 Browse & Filter Collection")
                if dfc.empty:
                    st.info("Your collection is empty. Add cards from the results to get started.")
                else:
                    def _row_est(r):
                        try:
                            if r.get("price_mid") and str(r.get("price_mid")) != "nan":
                                return float(r["price_mid"]) * int(r.get("quantity", 1))
                            elif r.get("price_market") and str(r.get("price_market")) != "nan":
                                return float(r["price_market"]) * int(r.get("quantity", 1))
                            elif r.get("price_low") and str(r.get("price_low")) != "nan":
                                return float(r["price_low"]) * int(r.get("quantity", 1))
                            elif r.get("price_usd") and str(r.get("price_usd")) != "nan":
                                return float(r["price_usd"]) * int(r.get("quantity", 1))
                            else:
                                return 0.0
                        except Exception:
                            return 0.0
                    
                    total_rows = len(dfc)
                    
                    # Advanced Filtering Section
                    st.write("#### 🎛️ Advanced Filters")
                    
                    # Expandable advanced filters
                    with st.expander("🔍 Filtering Options", expanded=True):
                        filter_col1, filter_col2 = st.columns(2)
                        
                        with filter_col1:
                            # Game filter
                            game_filter = st.selectbox("🎮 Filter by Game", ["All", "Pokémon", "Magic: The Gathering"], key="collection_game_filter")
                            
                            # Text search
                            search_term = st.text_input("🔍 Search Cards", placeholder="Search by name, set, or variant...", key="collection_search")
                            
                            # Set filter
                            if 'set' in dfc.columns:
                                available_sets = ['All Sets'] + sorted(dfc['set'].unique().tolist())
                                selected_set = st.selectbox("📚 Filter by Set", available_sets, key="collection_set_filter")
                        
                        with filter_col2:
                            # Price range
                            price_col1, price_col2 = st.columns(2)
                            with price_col1:
                                min_price = st.number_input("💰 Min Price", min_value=0.0, value=0.0, step=1.0, key="collection_min_price")
                            with price_col2:
                                max_price = st.number_input("💰 Max Price", min_value=0.0, value=1000.0, step=10.0, key="collection_max_price")
                            
                            # Quantity filter
                            min_quantity = st.number_input("🔢 Min Quantity", min_value=1, value=1, step=1, key="collection_min_qty")
                            
                            # Rarity/Type filter
                            rarity_filter = st.text_input("⭐ Rarity/Type Filter", placeholder="e.g., Rare, Holographic...", key="collection_rarity_filter")
                    
                    # Apply all filters
                    filtered_data = dfc.copy()
                    
                    # Game filter
                    if game_filter != "All":
                        filtered_data = filtered_data[filtered_data["game"] == game_filter]
                    
                    # Text search filter
                    if search_term:
                        search_term = search_term.lower()
                        text_mask = (
                            filtered_data['name'].str.lower().str.contains(search_term, na=False) |
                            filtered_data['set'].str.lower().str.contains(search_term, na=False) |
                            filtered_data.get('variant', pd.Series([''] * len(filtered_data))).str.lower().str.contains(search_term, na=False)
                        )
                        filtered_data = filtered_data[text_mask]
                    
                    # Set filter
                    if 'set' in dfc.columns and selected_set != 'All Sets':
                        filtered_data = filtered_data[filtered_data['set'] == selected_set]
                    
                    # Rarity/Type filter
                    if rarity_filter:
                        rarity_filter = rarity_filter.lower()
                        rarity_mask = (
                            filtered_data.get('variant', pd.Series([''] * len(filtered_data))).str.lower().str.contains(rarity_filter, na=False) |
                            filtered_data['name'].str.lower().str.contains(rarity_filter, na=False)
                        )
                        filtered_data = filtered_data[rarity_mask]
                    
                    # Price range filter
                    if min_price > 0 or max_price < 1000:
                        price_mask = filtered_data.apply(_row_est, axis=1).between(min_price, max_price)
                        filtered_data = filtered_data[price_mask]
                    
                    # Quantity filter
                    if 'quantity' in filtered_data.columns:
                        filtered_data = filtered_data[filtered_data['quantity'] >= min_quantity]
                    
                    # Filter summary
                    st.info(f"🎯 Showing {len(filtered_data)} of {total_rows} cards ({len(filtered_data)/total_rows*100:.1f}% of collection)")
                    
                    # Quick filter presets
                    st.write("#### ⚡ Quick Filters")
                    preset_col1, preset_col2, preset_col3, preset_col4 = st.columns(4)
                    
                    with preset_col1:
                        if st.button("💎 Valuable Cards", key="filter_valuable"):
                            st.session_state.collection_min_price = 50.0
                            st.rerun()
                    
                    with preset_col2:
                        if st.button("🆕 Recent Additions", key="filter_recent"):
                            st.info("📅 Recent additions filter coming soon!")
                    
                    with preset_col3:
                        if st.button("🔄 Reset All", key="reset_all_filters"):
                            for key in ['collection_search', 'collection_set_filter', 'collection_rarity_filter', 
                                       'collection_min_price', 'collection_max_price', 'collection_min_qty']:
                                if key in st.session_state:
                                    del st.session_state[key]
                            st.rerun()
                    
                    with preset_col4:
                        if st.button("❤️ Favorites", key="filter_favorites"):
                            st.session_state.collection_rarity_filter = "favorite"
                            st.rerun()
                    
                    # Sorting
                    st.write("#### 🔄 Sort Options")
                    sort_col1, sort_col2 = st.columns([1, 1])
                    with sort_col1:
                        sort_by = st.selectbox("Sort By", ["Name", "Value", "Set", "Quantity", "Game"], key="collection_sort_by")
                    with sort_col2:
                        sort_order = st.selectbox("Sort Order", ["Ascending", "Descending"], key="collection_sort_order")
                    
                    # Apply sorting
                    if sort_by == "Name":
                        filtered_data = filtered_data.sort_values('name', ascending=(sort_order == "Ascending"))
                    elif sort_by == "Value":
                        filtered_data = filtered_data.loc[filtered_data.apply(_row_est, axis=1).sort_values(ascending=(sort_order == "Ascending")).index]
                    elif sort_by == "Set":
                        filtered_data = filtered_data.sort_values('set_name', ascending=(sort_order == "Ascending"))
                    elif sort_by == "Quantity":
                        filtered_data = filtered_data.sort_values('quantity', ascending=(sort_order == "Ascending"))
                    elif sort_by == "Game":
                        filtered_data = filtered_data.sort_values('game', ascending=(sort_order == "Ascending"))
                    
                    # Display results
                    st.write("#### 📋 Filtered Results")
                    if not filtered_data.empty:
                        # Enhanced table with styling
                        styled_df = filtered_data.copy()
                        
                        # Add value column to display
                        styled_df['Card Value'] = styled_df.apply(_row_est, axis=1).round(2)
                        
                        # Reorder columns for better display
                        display_columns = ['name', 'set_name', 'quantity', 'Card Value', 'game']
                        if 'variant' in styled_df.columns:
                            display_columns.insert(2, 'variant')
                        
                        # Only show columns that exist
                        available_columns = [col for col in display_columns if col in styled_df.columns]
                        
                        st.dataframe(styled_df[available_columns], width='stretch', use_container_width=True)
                        
                        # Download filtered results
                        csv_bytes = filtered_data.to_csv(index=False).encode("utf-8")
                        filename = f"tcg_collection_filtered_{len(filtered_data)}_cards.csv"
                        st.download_button("📥 Download Filtered CSV", data=csv_bytes, file_name=filename, mime="text/csv")
                    else:
                        st.warning("No cards found matching your filters")
            
            with sub_tab3:
                st.write("### 🖼️ Gallery View")
                if dfc.empty:
                    st.info("Your collection is empty. Add cards from the results to get started.")
                else:
                    def _row_est(r):
                        try:
                            if r.get("price_mid") and str(r.get("price_mid")) != "nan":
                                return float(r["price_mid"]) * int(r.get("quantity", 1))
                            elif r.get("price_market") and str(r.get("price_market")) != "nan":
                                return float(r["price_market"]) * int(r.get("quantity", 1))
                            elif r.get("price_low") and str(r.get("price_low")) != "nan":
                                return float(r["price_low"]) * int(r.get("quantity", 1))
                            elif r.get("price_usd") and str(r.get("price_usd")) != "nan":
                                return float(r["price_usd"]) * int(r.get("quantity", 1))
                            else:
                                return 0.0
                        except Exception:
                            return 0.0
                    
                    # Gallery options and filters
                    with st.expander("🎨 Gallery Options & Filters", expanded=False):
                        gallery_col1, gallery_col2, gallery_col3, gallery_col4 = st.columns(4)
                        
                        with gallery_col1:
                            cards_per_row = st.selectbox("Cards per Row", [2, 3, 4, 5, 6], index=2, key="gallery_cards_per_row")
                        
                        with gallery_col2:
                            show_values = st.checkbox("Show Values", value=True, key="gallery_show_values")
                        
                        with gallery_col3:
                            show_quantities = st.checkbox("Show Quantities", value=True, key="gallery_show_quantities")
                        
                        with gallery_col4:
                            sort_by = st.selectbox("Sort By", ["Name", "Value", "Set", "Quantity", "Game"], key="gallery_sort_by")
                        
                        # Filter for gallery (simple game filter)
                        gallery_game_filter = st.selectbox("🎮 Filter by Game", ["All", "Pokémon", "Magic: The Gathering"], key="gallery_game_filter")
                    
                    if gallery_game_filter != "All":
                        gallery_data = dfc[dfc["game"] == gallery_game_filter].copy()
                    else:
                        gallery_data = dfc.copy()
                    
                    # Apply sorting to gallery data
                    if sort_by == "Name":
                        gallery_data = gallery_data.sort_values('name')
                    elif sort_by == "Value":
                        gallery_data = gallery_data.loc[gallery_data.apply(_row_est, axis=1).sort_values(ascending=False).index]
                    elif sort_by == "Set":
                        gallery_data = gallery_data.sort_values('set')
                    elif sort_by == "Quantity":
                        gallery_data = gallery_data.sort_values('quantity', ascending=False)
                    elif sort_by == "Game":
                        gallery_data = gallery_data.sort_values('game')
                    
                    st.write(f"#### 🖼️ Card Gallery ({len(gallery_data)} cards)")
                    
                    if not gallery_data.empty:
                        # Gallery grid
                        for i in range(0, len(gallery_data), cards_per_row):
                            cols = st.columns(cards_per_row)
                            for j, (_, card) in enumerate(gallery_data.iloc[i:i+cards_per_row].iterrows()):
                                with cols[j]:
                                    # Card container
                                    with st.container():
                                        # Card image
                                        img_url = card.get('image_url', '')
                                        card_name = card.get('name', 'Unknown')
                                        card_set = card.get('set', 'Unknown Set')
                                        card_game = card.get('game', 'Unknown')
                                        
                                        # Try to get local image first, otherwise use stored URL
                                        if img_url:
                                            if os.path.exists(img_url):
                                                # Local image exists
                                                st.image(img_url, width=150)
                                            else:
                                                # Check if we should download it locally
                                                local_img_url = get_local_image_url(card_game, card_name, card_set, img_url)
                                                if local_img_url != img_url and os.path.exists(local_img_url):
                                                    # New local image downloaded
                                                    st.image(local_img_url, width=150)
                                                    # Update the card data with local path
                                                    card['image_url'] = local_img_url
                                                else:
                                                    # Use original URL
                                                    st.image(img_url, width=150)
                                        else:
                                            st.image("https://via.placeholder.com/150x210?text=No+Image", width=150)
                                        
                                        # Card info (already defined above)
                                        card_value = _row_est(card)
                                        quantity = card.get('quantity', 1)
                                        variant = card.get('variant', '')
                                        
                                        # Set icon lookup
                                        def get_set_icon_url(game_name, set_name):
                                            """Get set icon/symbol URL for display with local storage"""
                                            try:
                                                original_url = None
                                                set_code = ""
                                                
                                                if "Pokémon" in game_name:
                                                    # Load Pokemon sets cache
                                                    pokemon_sets_file = CACHE_FILES.get("pokemon_sets")
                                                    if pokemon_sets_file and os.path.exists(pokemon_sets_file):
                                                        pokemon_sets = load_sets_from_csv(pokemon_sets_file)
                                                        for set_data in pokemon_sets:
                                                            if set_data.get('name') == set_name:
                                                                images = set_data.get('images', {})
                                                                if isinstance(images, dict):
                                                                    symbol_url = images.get('symbol')
                                                                    if symbol_url:
                                                                        original_url = symbol_url
                                                                        set_code = set_data.get('id', '')
                                                                        break
                                                
                                                elif "Magic" in game_name:
                                                    # Load MTG sets cache  
                                                    mtg_sets_file = CACHE_FILES.get("mtg_sets")
                                                    if mtg_sets_file and os.path.exists(mtg_sets_file):
                                                        mtg_sets = load_sets_from_csv(mtg_sets_file)
                                                        for set_data in mtg_sets:
                                                            if set_data.get('name') == set_name:
                                                                icon_svg_uri = set_data.get('icon_svg_uri')
                                                                if icon_svg_uri:
                                                                    original_url = icon_svg_uri
                                                                    set_code = set_data.get('code', '')
                                                                    break
                                                
                                                # Use local storage if we found an original URL
                                                if original_url:
                                                    return get_local_set_image_url(game_name, set_name, set_code, original_url)
                                                
                                                return None  # No icon found
                                                
                                            except Exception as e:
                                                print(f"Error loading set icon for {set_name}: {e}")
                                                return None  # No icon found
                                        
                                        set_icon_url = get_set_icon_url(card_game, card_set)
                                        
                                        # Display card name with icon
                                        icon_col, name_col = st.columns([1, 5])
                                        with icon_col:
                                            if set_icon_url:
                                                try:
                                                    # Check if it's an SVG file (MTG set icons are SVG)
                                                    if set_icon_url.endswith('.svg') or 'icon_svg_uri' in str(set_icon_url) or 'scryfall' in str(set_icon_url):
                                                        # For SVG files, we need to handle them differently
                                                        if os.path.exists(set_icon_url):
                                                            # Read SVG content and display as markdown
                                                            try:
                                                                with open(set_icon_url, 'r', encoding='utf-8') as f:
                                                                    svg_content = f.read()
                                                                st.markdown(svg_content, unsafe_allow_html=True)
                                                            except Exception:
                                                                # Fallback to game icon text
                                                                game_icon = "⚡" if "Pokémon" in card_game else "🃏"
                                                                st.write(game_icon)
                                                        else:
                                                            # Fallback to game icon text for remote SVG
                                                            game_icon = "⚡" if "Pokémon" in card_game else "🃏"
                                                            st.write(game_icon)
                                                    else:
                                                        # Regular image file (PNG, JPG, etc.) - wrap in try-catch
                                                        st.image(set_icon_url, width=24)
                                                except Exception as img_error:
                                                    # Any image display error - fall back to game icon
                                                    print(f"Error displaying set icon {set_icon_url}: {img_error}")
                                                    game_icon = "⚡" if "Pokémon" in card_game else "🃏"
                                                    st.write(game_icon)
                                            else:
                                                # Fallback to game icon text
                                                game_icon = "⚡" if "Pokémon" in card_game else "🃏"
                                                st.write(game_icon)
                                        
                                        with name_col:
                                            st.markdown(f"**{card_name}**")
                                        
                                        # Compact set and variant info
                                        info_text = card_set
                                        if variant:
                                            info_text += f" • {variant}"
                                        st.caption(info_text)
                                        
                                        # Optional info based on checkboxes
                                        info_parts = []
                                        if show_quantities and quantity > 1:
                                            info_parts.append(f"Qty: {quantity}")
                                        if show_values:
                                            info_parts.append(f"${card_value:.2f}")
                                        
                                        if info_parts:
                                            st.caption(" | ".join(info_parts))
                                        
                                        # Quick actions
                                        action_col1, action_col2 = st.columns(2)
                                        with action_col1:
                                            if st.button("✏️", key=f"gallery_edit_{i}_{j}", help="Edit Card"):
                                                st.info("Edit feature coming soon!")
                                        with action_col2:
                                            if st.button("🗑️", key=f"gallery_delete_{i}_{j}", help="Remove Card"):
                                                st.info("Delete feature coming soon!")
                    else:
                        st.warning("No cards to display in gallery")
            
            with sub_tab4:
                # Title and filter in same row
                title_col, filter_col = st.columns([3, 1])
                with title_col:
                    st.write("### 💰 Investment & Price Tracking")
                with filter_col:
                    # Show current filter status (read-only)
                    if master_game_filter != "Select Collection":
                        st.info(f"🎮 {master_game_filter}")
                    else:
                        st.info("🎮 All Games")
                
                if dfc.empty:
                    st.info("Your collection is empty. Add cards from the results to get started.")
                else:
                    def _row_est(r):
                        try:
                            if r.get("price_mid") and str(r.get("price_mid")) != "nan":
                                return float(r["price_mid"]) * int(r.get("quantity", 1))
                            elif r.get("price_market") and str(r.get("price_market")) != "nan":
                                return float(r["price_market"]) * int(r.get("quantity", 1))
                            elif r.get("price_low") and str(r.get("price_low")) != "nan":
                                return float(r["price_low"]) * int(r.get("quantity", 1))
                            elif r.get("price_usd") and str(r.get("price_usd")) != "nan":
                                return float(r["price_usd"]) * int(r.get("quantity", 1))
                            else:
                                return 0.0
                        except Exception:
                            return 0.0
                    
                    total_rows = len(dfc)
                    est_total = sum(_row_est(row) for _, row in dfc.iterrows())
                    pokemon_count = len(dfc[dfc["game"] == "Pokémon"])
                    mtg_count = len(dfc[dfc["game"] == "Magic: The Gathering"])
                    
                    # Use master filter data for all subsequent calculations
                    analysis_dfc = dfc
                    analysis_total = est_total
                    analysis_rows = total_rows
                    
                    # Top metrics row
                    st.write("#### 📊 Portfolio Overview")
                    metric_col1, metric_col2, metric_col3, metric_col4 = st.columns(4)
                    
                    with metric_col1:
                        st.metric("💰 Total Value", f"${analysis_total:,.2f}")
                    
                    with metric_col2:
                        avg_card_value = analysis_total / analysis_rows if analysis_rows > 0 else 0
                        st.metric("💎 Avg Card Value", f"${avg_card_value:.2f}")
                    
                    with metric_col3:
                        high_value_count = sum(1 for _, card in analysis_dfc.iterrows() if _row_est(card) > 50)
                        st.metric("🔥 High Value Cards", f"{high_value_count}")
                    
                    with metric_col4:
                        st.metric("📚 Total Cards", f"{analysis_rows}")
                    
                    # Main investment insights
                    st.write("#### 🎯 Investment Insights")
                    
                    insight_col1, insight_col2 = st.columns(2)
                    
                    with insight_col1:
                        # Value Distribution with visual progress bars
                        st.write("**💰 Value Distribution**")
                        
                        value_ranges = {
                            "Under $10": 0,
                            "$10-$25": 0, 
                            "$25-$50": 0,
                            "$50-$100": 0,
                            "Over $100": 0
                        }
                        
                        for _, card in analysis_dfc.iterrows():
                            card_value = _row_est(card)
                            if card_value < 10:
                                value_ranges["Under $10"] += 1
                            elif card_value < 25:
                                value_ranges["$10-$25"] += 1
                            elif card_value < 50:
                                value_ranges["$25-$50"] += 1
                            elif card_value < 100:
                                value_ranges["$50-$100"] += 1
                            else:
                                value_ranges["Over $100"] += 1
                        
                        # Display with progress bars
                        for range_name, count in value_ranges.items():
                            if count > 0:
                                percentage = (count / analysis_rows) * 100
                                st.write(f"**{range_name}:** {count} cards")
                                st.progress(percentage / 100, text=f"{percentage:.1f}%")
                    
                    with insight_col2:
                        # Collection Health Score with visual design
                        st.write("**🏆 Collection Health Score**")
                        
                        health_score = 0
                        health_factors = []
                        
                        # Diversity score
                        if 'set' in analysis_dfc.columns:
                            unique_sets = analysis_dfc['set'].nunique()
                            diversity_score = min(unique_sets / 10, 1.0) * 25
                            health_score += diversity_score
                            health_factors.append(("Set Diversity", diversity_score))
                        
                        # Value distribution score
                        if analysis_rows > 0:
                            valuable_cards = sum(1 for _, card in analysis_dfc.iterrows() if _row_est(card) > 25)
                            value_score = min(valuable_cards / analysis_rows, 1.0) * 25
                            health_score += value_score
                            health_factors.append(("Value Distribution", value_score))
                        
                        # Game balance score (only relevant for "Select Collection" view)
                        if master_game_filter == "Select Collection" and pokemon_count > 0 and mtg_count > 0:
                            balance_ratio = min(pokemon_count, mtg_count) / max(pokemon_count, mtg_count)
                            balance_score = balance_ratio * 25
                            health_score += balance_score
                            health_factors.append(("Game Balance", balance_score))
                        else:
                            health_score += 10
                            health_factors.append(("Game Balance", 10))
                        
                        # Completion score
                        completion_score = min(analysis_rows / 50, 1.0) * 25
                        health_score += completion_score
                        health_factors.append(("Collection Size", completion_score))
                        
                        # Visual health score display
                        health_color = "🟢" if health_score >= 75 else "🟡" if health_score >= 50 else "🔴"
                        health_label = "Excellent" if health_score >= 75 else "Good" if health_score >= 50 else "Needs Improvement"
                        
                        st.markdown(f"### {health_color} {health_score:.1f}/100")
                        st.caption(f"**Status:** {health_label}")
                        
                        st.write("**Score Breakdown:**")
                        for factor_name, score in health_factors:
                            st.progress(score / 25, text=f"{factor_name}: {score:.1f}/25")
                    
                    # Top valuable cards section
                    st.write("#### 💎 Most Valuable Cards")
                    
                    top_cards = analysis_dfc.loc[analysis_dfc.apply(_row_est, axis=1).sort_values(ascending=False).head(5).index]
                    
                    if not top_cards.empty:
                        for i, (_, card) in enumerate(top_cards.iterrows()):
                            card_value = _row_est(card)
                            card_name = card.get('name', 'Unknown')
                            card_set = card.get('set', 'Unknown Set')
                            
                            # Create a nice card-like display for each valuable card
                            with st.container():
                                col1, col2, col3 = st.columns([1, 4, 1])
                                with col1:
                                    st.write(f"**#{i+1}**")
                                with col2:
                                    st.write(f"**{card_name}**")
                                    st.caption(f"{card_set}")
                                with col3:
                                    st.write(f"**${card_value:,.2f}**")
                                
                                if i < len(top_cards) - 1:
                                    st.divider()
                    
                    # Investment alerts and opportunities
                    st.write("#### 🚨 Investment Alerts & Opportunities")
                    
                    alert_col1, alert_col2, alert_col3 = st.columns(3)
                    
                    with alert_col1:
                        st.write("**💎 High Value Assets**")
                        high_value = analysis_dfc[analysis_dfc.apply(_row_est, axis=1) > 50]
                        if not high_value.empty:
                            for _, card in high_value.head(3).iterrows():
                                card_value = _row_est(card)
                                card_name = card.get('name', 'Unknown')
                                st.write(f"💰 {card_name}")
                                st.caption(f"${card_value:.2f}")
                        else:
                            st.info("No cards over $50")
                    
                    with alert_col2:
                        st.write("**📈 Growth Opportunities**")
                        st.info("📊 Price tracking coming soon!")
                        st.caption("Monitor cards with potential upside")
                    
                    with alert_col3:
                        st.write("**🎯 Target Price Alerts**")
                        st.info("🎯 Price alerts coming soon!")
                        st.caption("Get notified when cards hit target prices")
                    
                    # Investment reports section
                    st.write("#### 📊 Investment Reports & Tools")
                    
                    report_col1, report_col2, report_col3, report_col4 = st.columns(4)
                    
                    with report_col1:
                        if st.button("📑 Tax Report", key="tax_report", help="Generate tax-ready collection report"):
                            st.info("🧾 Tax report generation coming soon!")
                    
                    with report_col2:
                        if st.button("🛡️ Insurance Valuation", key="insurance_report", help="Get collection valuation for insurance"):
                            st.info("📋 Insurance valuation report coming soon!")
                    
                    with report_col3:
                        if st.button("📈 Performance Analysis", key="performance_report", help="Analyze collection performance over time"):
                            st.info("📊 Performance analysis coming soon!")
                    
                    with report_col4:
                        if st.button("📤 Export Portfolio", key="export_portfolio", help="Export detailed portfolio data"):
                            st.info("📑 Portfolio export coming soon!")
            
            with sub_tab5:
                st.write("### 🛠️ Collection Management Tools")
                if dfc.empty:
                    st.info("Your collection is empty. Add cards from the results to get started.")
                else:
                    # Collection Management Tools
                    st.write("#### 🔍 Management Tools")
                    
                    mgmt_col1, mgmt_col2, mgmt_col3 = st.columns(3)
                    
                    with mgmt_col1:
                        st.write("**🔍 Duplicate Detection**")
                        if st.button("🔍 Find Duplicates", key="find_duplicates"):
                            duplicates = []
                            # Check for duplicate cards (same name and set)
                            card_groups = dfc.groupby(['name', 'set'])
                            for (name, set_name), group in card_groups:
                                if len(group) > 1:
                                    duplicates.append({
                                        'name': name,
                                        'set': set_name,
                                        'count': len(group),
                                        'total_quantity': group['quantity'].sum()
                                    })
                            
                            if duplicates:
                                st.warning(f"Found {len(duplicates)} potential duplicates:")
                                for dup in duplicates[:5]:  # Show first 5
                                    st.write(f"• {dup['name']} ({dup['set']}) - {dup['count']} entries, {dup['total_quantity']} total")
                            else:
                                st.success("No duplicates found!")
                    
                    with mgmt_col2:
                        st.write("**📦 Storage Organization**")
                        storage_location = st.text_input("📍 Storage Location", placeholder="e.g., Binder 1, Box A", key="storage_location")
                        if st.button("📋 Organize by Set", key="organize_by_set"):
                            if 'set' in dfc.columns:
                                set_groups = dfc.groupby('set')
                                st.info(f"Collection spans {len(set_groups)} different sets")
                                for set_name, group in set_groups:
                                    st.write(f"📚 {set_name}: {len(group)} cards")
                    
                    with mgmt_col3:
                        st.write("**🏷️ Tag Management**")
                        new_tag = st.text_input("➕ Add Tag", placeholder="e.g., Favorite, Trade, Deck", key="new_tag")
                        if st.button("🏷️ Apply to Selected", key="apply_tag"):
                            st.info("🏷️ Tag management feature coming soon!")
                    
                    # Bulk Actions
                    st.write("#### ⚡ Bulk Actions")
                    
                    bulk_col1, bulk_col2, bulk_col3, bulk_col4 = st.columns(4)
                    
                    with bulk_col1:
                        if st.button("🔄 Bulk Price Update", key="bulk_price_update"):
                            st.info("💰 Bulk price update feature coming soon!")
                    
                    with bulk_col2:
                        if st.button("📥 Download Full CSV", key="download_full_csv"):
                            csv_bytes = dfc.to_csv(index=False).encode("utf-8")
                            st.download_button("📥 Download", data=csv_bytes, file_name="tcg_collection_full.csv", mime="text/csv")
                    
                    with bulk_col3:
                        if st.button("📤 Backup Collection", key="backup_collection"):
                            st.info("💾 Collection backup feature coming soon!")
                    
                    with bulk_col4:
                        if st.button("🔗 Share Collection", key="share_collection"):
                            st.info("🔗 Sharing features coming soon!")
                    
                    # Refresh prices
                    st.write("#### 🔄 Price Management")
                    
                    price_col1, price_col2, price_col3 = st.columns(3)
                    
                    with price_col1:
                        if st.button("🔄 Refresh All Prices", key="refresh_all_prices"):
                            with st.spinner("Refreshing prices..."):
                                try:
                                    # Refresh prices for each row
                                    refreshed = dfc.copy()
                                    for idx, row in dfc.iterrows():
                                        game = row.get("game", "")
                                        name = row.get("name", "")
                                        set_name = row.get("set_name", "")
                                        if game == "Magic: The Gathering":
                                            cards = scryfall_search_all(name, set_name)
                                            if cards:
                                                card = cards[0]
                                                ps = scryfall_card_price_summary(card)
                                                refreshed.at[idx, "price_usd"] = ps.get("usd")
                                                refreshed.at[idx, "price_usd_foil"] = ps.get("usd_foil")
                                                refreshed.at[idx, "price_usd_etched"] = ps.get("usd_etched")
                                        elif game == "Pokémon":
                                            cards, _, _, _ = pokemontcg_search_multi_source(name.strip(), set_name.strip() if set_name else None, None, pokemon_api_key=get_secret("POKEMONTCG_API_KEY"), justtcg_api_key=get_secret("JUSTTCG_API_KEY"), limit=10)
                                            if cards:
                                                card = cards[0]
                                                refreshed.at[idx, "price_low"] = card.get("cardmarket", {}).get("prices", {}).get("averageSellPrice")
                                                refreshed.at[idx, "price_mid"] = card.get("cardmarket", {}).get("prices", {}).get("averageSellPrice")  # Using same for now
                                                refreshed.at[idx, "price_market"] = card.get("tcgplayer", {}).get("prices", {}).get("market")
                                    
                                    # Update collection file
                                    refresh_success = refresh_collection_csv(refreshed)
                                    if refresh_success:
                                        st.success(f"✅ Refreshed prices for {len(refreshed)} cards!")
                                        st.rerun()
                                    else:
                                        st.error("❌ Failed to update collection file")
                                except Exception as e:
                                    st.error(f"Failed to refresh prices: {e}")
                    
                    with price_col2:
                        st.caption("💾 Prices are automatically snapshotted before refresh")
                    
                    with price_col3:
                        last_updated = "Unknown"  # This would come from a timestamp field
                        st.caption(f"📅 Last updated: {last_updated}")
                with col2:
                    st.caption("💾 Prices are automatically snapshotted before refresh")
        
        with watchlist_tab:
            st.write("**Your Watchlist**")
            wl_df = load_watchlist_dataframe()
            total_wl = len(wl_df)
            
            if total_wl == 0:
                st.info("Your watchlist is empty. Add cards to watchlist from search results to track them.")
            else:
                st.write(f"**{total_wl} cards in watchlist**")
                
                # Game filter for watchlist
                st.write("**Filter by Game:**")
                col1, col2, col3 = st.columns([1, 1, 2])
                with col1:
                    wl_game_filter = st.selectbox("Select Game", ["All", "Pokémon", "Magic: The Gathering"], key="watchlist_game_filter")
                with col2:
                    if st.button("🔄 Reset Filter", key="reset_wl_filter"):
                        st.session_state.watchlist_game_filter = "All"
                        st.rerun()
                with col3:
                    st.write("")  # Empty column for spacing
                
                # Apply game filter to watchlist
                if wl_game_filter != "All":
                    filtered_wl_df = wl_df[wl_df["game"] == wl_game_filter].copy()
                    st.info(f"Showing {len(filtered_wl_df)} {wl_game_filter} cards ({total_wl} total)")
                else:
                    filtered_wl_df = wl_df.copy()
                
                # Pagination for watchlist
                items_per_page = 10
                if "wl_page" not in st.session_state:
                    st.session_state["wl_page"] = 1
                total_pages = max(1, (len(filtered_wl_df) + items_per_page - 1) // items_per_page)
                page = st.session_state.get("wl_page", 1)
                start_idx = (page - 1) * items_per_page
                end_idx = start_idx + items_per_page
                page_df = filtered_wl_df.iloc[start_idx:end_idx]
                
                # Pagination controls
                if total_pages > 1:
                    pcol1, pcol2, pcol3 = st.columns([1, 2, 1])
                    with pcol1:
                        if st.button("← Prev", key="wl_prev", disabled=page <= 1):
                            st.session_state["wl_page"] = page - 1
                            st.rerun()
                    with pcol2:
                        st.write(f"Page {page}/{total_pages}")
                    with pcol3:
                        if st.button("Next →", key="wl_next", disabled=page >= total_pages):
                            st.session_state["wl_page"] = page + 1
                            st.rerun()
                
                # Display watchlist items with actions
                for idx, (_, row) in enumerate(page_df.iterrows()):
                    name = row.get("name", "")
                    set_full = row.get("set", "")
                    variant = row.get("variant", "")
                    price_mid = row.get("price_mid")
                    game = row.get("game", "")
                    img_url = row.get("image_url", "")
                    
                    with st.container():
                        col1, col2 = st.columns([1, 3])
                        
                        with col1:
                            if img_url:
                                st.image(img_url, width=100)
                        
                        with col2:
                            st.markdown(f"**{name}** — {set_full}{(' — ' + variant) if variant else ''}")
                            st.caption(f"Game: {game}")
                            if price_mid and str(price_mid) != "nan":
                                st.caption(f"Price: ${float(price_mid):.2f}")
                            
                            # Actions
                            rcols = st.columns([1, 1, 1])
                            qty = rcols[0].number_input("Qty", min_value=1, max_value=999, value=1, step=1, key=f"wl_qty_{start_idx + idx}")
                            if rcols[1].button("Add to collection", key=f"wl_add_{start_idx + idx}"):
                                ok, msg = add_to_collection(
                                    game=row.get("game", ""),
                                    name=name,
                                    set_name=set_full,
                                    link=row.get("link", ""),
                                    image_url=row.get("image_url", ""),
                                    prices={"low": row.get("price_low"), "mid": row.get("price_mid"), "market": row.get("price_market"), "usd": None, "usd_foil": None, "usd_etched": None},
                                    quantity=qty,
                                    variant=variant,
                                )
                                if ok:
                                    st.session_state["last_added"] = {"name": name, "set": set_full, "quantity": int(qty), "variant": variant}
                                    st.toast("Added from watchlist")
                                    # Don't rerun here to avoid unnecessary API calls
                                else:
                                    st.error(f"Failed to save: {msg}")
                            if rcols[2].button("Remove", key=f"wl_rm_{start_idx + idx}"):
                                try:
                                    wl_df = wl_df.drop(row.name)
                                    save_watchlist_dataframe(wl_df)
                                    st.toast("Removed from watchlist")
                                    st.rerun()
                                except Exception:
                                    pass
                        
                        st.divider()
        
        st.divider()
        if st.button("Back to search"):
            st.session_state[SESSION_KEYS["show_collection_view"]] = False
            st.session_state[SESSION_KEYS["show_sets_view"]] = False
            st.session_state[SESSION_KEYS["show_mtg_sets_view"]] = False
            st.rerun()
        st.stop()

    last_query = st.session_state.get(SESSION_KEYS["last_query"])
    if last_query:
        game = last_query.get("game", "")
        card_name = last_query.get("card_name", "")
        set_name = last_query.get("set_name", "")
        set_number = last_query.get("set_number", "")
        
        # Create a unique key for this search query
        query_key = f"{game}_{card_name}_{set_name}_{set_number}"
        
        if not (card_name or "").strip():
            st.warning("Please enter a card name.")
        else:
            # Check if we have cached results for this query
            cached_results = st.session_state.get(f"search_results_{query_key}")
            cached_source = st.session_state.get(f"search_source_{query_key}")
            cached_total = st.session_state.get(f"search_total_{query_key}")
            
            if cached_results is not None:
                # Use cached results
                cards_all = cached_results
                source = cached_source
                total = cached_total
                if st.session_state.get("debug_mode", False):
                    st.write(f"🎯 Using cached results for: {query_key}")
            else:
                # Perform new search and cache results
                if game == "Magic: The Gathering":
                    with st.spinner("Searching Scryfall for MTG prices..."):
                        cards_all = scryfall_search_all(card_name.strip(), (set_name or "").strip() or None, (set_number or "").strip() or None)
                    source = "Scryfall API"
                    total = len(cards_all)
                elif game == "Baseball Cards":
                    # Extract baseball-specific fields
                    year = last_query.get("year", "")
                    team = last_query.get("team", "")
                    baseball_card_number = last_query.get("card_number", "")
                    
                    # Check which sources are enabled
                    sportscarddatabase_enabled = st.session_state.get("sportscarddatabase_enabled", True)
                    sportscardspro_enabled = False  # Temporarily disabled due to 403 errors
                    ebay_baseball_enabled = st.session_state.get("ebay_baseball_enabled", True)
                    
                    cards_all = []
                    source_used = "No Source"
                    
                    # Try SportsCardDatabase.com first if enabled
                    if sportscarddatabase_enabled and not cards_all:
                        with st.spinner(f"🔍 Searching SportsCardDatabase.com for {card_name.strip()}..."):
                            cards, total, api_count, source = search_sportscard_database(
                                card_name.strip(),
                                year.strip() if year else "",
                                set_name.strip() if set_name else "",
                                baseball_card_number.strip() if baseball_card_number else ""
                            )
                            if cards:
                                cards_all = cards
                                source_used = source
                    
                    # Try SportCardsPro.com if enabled and no cards found yet
                    if sportscardspro_enabled and not cards_all:
                        with st.spinner(f"🔍 Searching SportCardsPro.com for {card_name.strip()}..."):
                            cards, total, api_count, source = search_sportscardspro(
                                card_name.strip(),
                                year.strip() if year else "",
                                set_name.strip() if set_name else "",
                                baseball_card_number.strip() if baseball_card_number else ""
                            )
                            if cards:
                                cards_all = cards
                                source_used = source
                    
                    # Try eBay as fallback if enabled and no cards found yet
                    if ebay_baseball_enabled and not cards_all:
                        with st.spinner(f"🔍 Searching eBay for {card_name.strip()}..."):
                            cards, total, api_count, source = baseball_search_ebay(
                                card_name.strip(), 
                                year.strip() if year else "", 
                                team.strip() if team else "",
                                set_name.strip() if set_name else "",
                                baseball_card_number.strip() if baseball_card_number else ""
                            )
                            if cards:
                                cards_all = cards
                                source_used = source
                    
                    # If no sources are enabled or no results found
                    if not cards_all:
                        st.warning("❌ No baseball card sources enabled or no results found")
                        st.info("💡 Please enable at least one baseball card source in API Sources settings")
                        cards_all = []
                        total = 0
                        source_used = "No Enabled Sources"
                    else:
                        total = len(cards_all)
                
                    if cards_all:
                        process_search_results(game, cards_all)
                        st.info(f"✅ Saved {len(cards_all)} cards to local cache with images")
                
                    # Cache in session state
                    st.session_state[f"search_results_{query_key}"] = cards_all
                    st.session_state[f"search_source_{query_key}"] = source_used
                    st.session_state[f"search_total_{query_key}"] = total
                else:  # Pokémon
                    with st.spinner("Searching Pokémon TCG API for prices..."):
                        # Check debug mode
                        debug_mode = st.session_state.get("debug_mode", False)
                        if debug_mode:
                            st.write("Debug mode enabled - showing detailed API info")
                        
                        cards_all, total, api_count, source = pokemontcg_search_all(
                            card_name.strip(), (set_name or "").strip() or None, (set_number or "").strip() or None, 
                            limit=50, pokemon_api_key=pokemon_api_key, justtcg_api_key=justtcg_api_key
                        )
                
                # Display results (using cached or fresh data)
                tabs = st.tabs(["Results"])
                with tabs[0]:
                    # Display source information in columns
                    col_results, col_source = st.columns([1, 1])
                    with col_results:
                        if game == "Magic: The Gathering":
                            st.caption(f"Found {total} MTG prints")
                        elif game == "Baseball Cards":
                            st.caption(f"Found {total} Baseball cards")
                        else:  # Pokémon
                            st.caption(f"Found {total} Pokémon results")
                    with col_source:
                        if source and source != "No Source":
                            st.caption(f"📡 Source: {source}")
                        else:
                            st.caption("📡 Source: No Source")
                
                    # Pagination and display logic
                if game == "Magic: The Gathering":
                    total_pages = max(1, math.ceil(total / max(1, 1 if total <= 20 else 20)))
                    if "page_mtg" not in st.session_state:
                        st.session_state["page_mtg"] = 1
                    page = int(st.session_state.get("page_mtg", 1))
                    start = (page - 1) * 20
                    end = min(start + 20, total)
                    cards = cards_all[start:end]
                    if view_mode == "Grid":
                        render_mtg_grid(cards, per_row=cards_per_row, image_width=image_width)
                    else:
                        render_mtg_list(cards, image_width=image_width)
                else:  # Pokémon
                    per_page_local = per_page
                    total_pages = max(1, math.ceil(max(1, total) / per_page_local))
                    if "page_pkmn" not in st.session_state:
                        st.session_state["page_pkmn"] = 1
                    page = int(st.session_state.get("page_pkmn", 1))
                    page = max(1, min(page, total_pages))
                    start = (page - 1) * per_page_local
                    end = min(start + per_page_local, total)
                    cards = cards_all[start:end]
                    if view_mode == "Grid":
                        render_pokemon_grid(cards, per_row=cards_per_row, image_width=image_width)
                    else:
                        render_pokemon_list(cards, image_width=image_width)

def load_watchlist_dataframe() -> pd.DataFrame:
    try:
        if os.path.exists(WATCHLIST_CSV_PATH):
            return pd.read_csv(WATCHLIST_CSV_PATH)
    except Exception:
        pass
    cols = [
        "timestamp",
        "game",
        "name",
        "set",
        "link",
        "image_url",
        "price_low",
        "price_mid",
        "price_market",
        "variant",
    ]
    return pd.DataFrame(columns=cols)


def save_watchlist_dataframe(df: pd.DataFrame):
    try:
        df.to_csv(WATCHLIST_CSV_PATH, index=False)
    except Exception:
        pass


def add_to_collection(game: str, name: str, set_name: str, link: str, image_url: str,
                      prices: Dict[str, Optional[float]], quantity: int, variant: Optional[str] = None):
    df = load_collection_dataframe()
    
    # Store image locally and get local path
    local_image_url = store_card_image_locally(game, name, set_name, image_url)
    
    row = {
        "game": game,
        "name": name,
        "set": set_name,
        "link": link,
        "image_url": local_image_url,
        "price_low": prices.get("low"),
        "price_mid": prices.get("mid"),
        "price_market": prices.get("market"),
        "price_usd": prices.get("usd"),
        "price_usd_foil": prices.get("usd_foil"),
        "price_usd_etched": prices.get("usd_etched"),
        "quantity": quantity,
        "variant": variant or "",
    }
    # ensure all columns exist
    for k in row.keys():
        if k not in df.columns:
            df[k] = None
    df.loc[len(df)] = {col: row.get(col) for col in df.columns}
    save_collection_dataframe(df)
    return True, None


# Local Image Storage Functions
def get_card_image_path(game: str, card_name: str, set_name: str = "", image_url: str = "") -> str:
    """Generate local path for storing card images"""
    # Create safe filename
    safe_name = re.sub(r'[^\w\s-]', '', card_name).strip()
    safe_name = re.sub(r'[-\s]+', '_', safe_name)
    
    if set_name:
        safe_set = re.sub(r'[^\w\s-]', '', set_name).strip()
        safe_set = re.sub(r'[-\s]+', '_', safe_set)
        filename = f"{safe_name}_{safe_set}.jpg"
    else:
        filename = f"{safe_name}.jpg"
    
    # Determine base path relative to script directory
    script_dir = os.path.dirname(os.path.abspath(__file__))
    if "Pokémon" in game or "Pokemon" in game:
        base_path = os.path.join(script_dir, "fallback_data", "Pokemon", "CardImages")
    else:
        base_path = os.path.join(script_dir, "fallback_data", "MTG", "CardImages")
    
    return os.path.join(base_path, filename)


def download_card_image(image_url: str, local_path: str) -> bool:
    """Download and save card image locally"""
    try:
        # Create directory if it doesn't exist
        os.makedirs(os.path.dirname(local_path), exist_ok=True)
        
        # Download image with timeout
        response = requests.get(image_url, timeout=30, stream=True)
        response.raise_for_status()
        
        # Save image
        with open(local_path, 'wb') as f:
            for chunk in response.iter_content(chunk_size=8192):
                f.write(chunk)
        
        return True
    except Exception as e:
        print(f"Failed to download image {image_url}: {e}")
        return False


def get_local_image_url(game: str, card_name: str, set_name: str = "", image_url: str = "") -> str:
    """Get local image URL if available, otherwise return original URL"""
    local_path = get_card_image_path(game, card_name, set_name, image_url)
    
    # If local image exists, return file path
    if os.path.exists(local_path):
        return local_path
    
    # If no local image, try to download it
    if image_url and image_url.startswith('http'):
        if download_card_image(image_url, local_path):
            return local_path
    
    # Return original URL if all else fails
    return image_url


def store_card_image_locally(game: str, card_name: str, set_name: str, image_url: str) -> str:
    """Store card image locally and return local path"""
    if not image_url or not image_url.startswith('http'):
        return image_url  # Return original if not a valid URL
    
    local_path = get_card_image_path(game, card_name, set_name, image_url)
    
    # Download if not exists
    if not os.path.exists(local_path):
        download_card_image(image_url, local_path)
    
    return local_path if os.path.exists(local_path) else image_url


