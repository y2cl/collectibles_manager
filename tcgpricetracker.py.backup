        params = {
            "q": f"name:{card_name}*",
            "pageSize": 25
        }
        if set_name:
            params["q"] += f" set.name:{set_name}*"
        
        response = requests.get(url, params=params, timeout=10)
        if response.status_code == 200:
            data = response.json()
            return data.get("data", [])
    except Exception:
        pass
    return []

def pokemontcg_search_multi_source(name: str, set_name: Optional[str] = None, set_number: Optional[str] = None, pokemon_api_key: Optional[str] = None, justtcg_api_key: Optional[str] = None, limit: int = 10, exact_match: bool = False) -> Tuple[List[Dict], int, int, str]:
    """Multi-source Pokémon card search respecting user API toggle settings from JSON file."""
    logger.info(f"Multi-source search: name='{name}', set='{set_name}', number='{set_number}'")
    
    # Get debug mode from session state
    debug_mode = st.session_state.get("debug_mode", False)
    if debug_mode:
        st.write(f"Debug multi-source: name='{name}', set='{set_name}', number='{set_number}'")
    
    # Load user settings from JSON file (not session state)
    toggle_settings = load_toggle_settings()
    pokemon_enabled = toggle_settings.get("pokemon_enabled", True)
    justtcg_enabled = toggle_settings.get("justtcg_enabled", True)
    public_enabled = toggle_settings.get("public_enabled", True)
    fallback_enabled = toggle_settings.get("fallback_enabled", True)
    
    # Debug: Show settings being used
    logger.info(f"JSON Settings: pokemon_enabled={pokemon_enabled}, justtcg_enabled={justtcg_enabled}, public_enabled={public_enabled}, fallback_enabled={fallback_enabled}")
    if debug_mode:
        st.write(f"Debug: JSON Settings loaded - pokemon_enabled={pokemon_enabled}, justtcg_enabled={justtcg_enabled}, public_enabled={public_enabled}, fallback_enabled={fallback_enabled}")
    
    results = []
    api_count = 0
    total_count = 0
    
    # Try sources in order based on enabled toggles - stop after first successful source
    logger.info("Trying enabled sources...")
    
    # Try JustTCG first if enabled
    if justtcg_enabled and justtcg_api_key:
        logger.info("Trying JustTCG...")
        try:
            justtcg_results, justtcg_err, _ = justtcg_search(name, set_name, justtcg_api_key, limit)
            if justtcg_err:
                logger.warning(f"JustTCG failed: {justtcg_err}")
            else:
                logger.info(f"JustTCG returned {len(justtcg_results)} cards")
                if debug_mode:
                    st.write(f"Debug: JustTCG results = {justtcg_results}")
                if justtcg_results:
                    results.extend(justtcg_results)
                    api_count += len(justtcg_results)
                    logger.info("JustTCG succeeded, stopping search")
                    return results[:limit], api_count, 1, "JustTCG"
                else:
                    logger.info("JustTCG returned 0 cards, continuing to next source")
        except Exception as e:
            logger.warning(f"JustTCG exception: {e}")
    
    # Try official Pokémon API if enabled
    if pokemon_enabled and pokemon_api_key:
        logger.info("Trying official API...")
        try:
            api_cards, api_total, _ = pokemontcg_search(name, set_name, set_number, pokemon_api_key, limit - api_count, exact_match)
            if api_cards:
                logger.info(f"Official API returned {len(api_cards)} cards")
                results.extend(api_cards)
                api_count += len(api_cards)
                total_count += api_total
                logger.info("Official API succeeded, stopping search")
                return results[:limit], api_count, 1, "Pokémon TCG API"
        except Exception as e:
            logger.warning(f"Official API exception: {e}")
    
    # Try public endpoint if enabled
    if public_enabled:
        logger.info("Trying public endpoint...")
        try:
            public_cards, public_total, _ = pokemontcg_search_public(name, set_name, limit - api_count)
            if public_cards:
                logger.info(f"Public endpoint returned {len(public_cards)} cards")
                results.extend(public_cards)
                api_count += len(public_cards)
                total_count += public_total
                logger.info("Public endpoint succeeded, stopping search")
                return results[:limit], api_count, 1, "Public Endpoint"
        except Exception as e:
            logger.warning(f"Public endpoint exception: {e}")
    
    # Try fallback if still no results
    if fallback_enabled and not results:
        logger.info("Trying fallback data...")
        try:
            fallback_results, fallback_total, _ = pokemontcg_search_fallback(name, set_name, set_number)
            if fallback_results:
                logger.info(f"Fallback returned {len(fallback_results)} cards")
                results.extend(fallback_results)
                api_count += len(fallback_results)
                total_count += fallback_total
                return results[:limit], api_count, 1, "Fallback Data"
        except Exception as e:
            logger.warning(f"Fallback exception: {e}")
    
    # No sources succeeded
    return results, total_count, 1, "No Source"

