# JSON file for storing toggle settings
TOGGLE_SETTINGS_FILE = os.path.join(SCRIPT_DIR, "toggle_settings.json")

def load_toggle_settings():
    """Load toggle settings from JSON file"""
    default_settings = {
        "pokemon_enabled": True,
        "justtcg_enabled": False,
        "public_enabled": False,
        "fallback_enabled": False,
        "scryfall_enabled": True
    }
    
    if os.path.exists(TOGGLE_SETTINGS_FILE):
        try:
            with open(TOGGLE_SETTINGS_FILE, 'r') as f:
                settings = json.load(f)
                # Merge with defaults to ensure all keys exist
                return {**default_settings, **settings}
        except Exception as e:
            logger.warning(f"Failed to load toggle settings: {e}")
    
    return default_settings

def save_toggle_settings(settings):
    """Save toggle settings to JSON file"""
    try:
        with open(TOGGLE_SETTINGS_FILE, 'w') as f:
            json.dump(settings, f, indent=2)
    except Exception as e:
        logger.error(f"Failed to save toggle settings: {e}")

def update_toggle_setting(key, value):
    """Update a single toggle setting and save to file"""
    settings = load_toggle_settings()
    settings[key] = value
    save_toggle_settings(settings)

def get_secret(name: str, default: Optional[str] = None) -> Optional[str]:
    try:
        return st.secrets.get(name, os.getenv(name, default))
    except Exception:
        return os.getenv(name, default)


