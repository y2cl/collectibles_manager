def pokemontcg_search_fallback(name: str, set_name: Optional[str] = None, set_number: Optional[str] = None) -> Tuple[List[Dict], int, int]:
    """Fallback search using cached data when API fails"""
    results = []
    
    # Simple name matching for fallback
    for card_name, card_data in POKEMON_FALLBACK_DATA.items():
        if name.lower() in card_name.lower():
            # Apply filters if provided
            if set_name and set_name.lower() not in card_data["set"].lower():
                continue
            if set_number and set_number != card_data["number"]:
                continue
                
            # Format like API response
            formatted_card = {
                "id": f"fallback-{card_name.lower()}",
                "name": card_data["name"],
                "images": {"large": card_data["image_url"]},
                "set": {"name": card_data["set"]},
                "number": card_data["number"],
                "tcgplayer": {
                    "prices": {
                        "normal": card_data["prices"]
                    }
                },
                "fallback": True  # Mark as fallback data
            }
            results.append(formatted_card)
    
    return results, len(results), 1

def scryfall_search_all(name: str, set_name: Optional[str] = None, set_number: Optional[str] = None) -> List[Dict]:
    """Search Scryfall API for MTG cards with fallback data storage."""
    # Check if Scryfall is enabled
    scryfall_enabled = st.session_state.get("scryfall_enabled", True)
    
    if not scryfall_enabled:
        st.warning("Scryfall API is disabled in settings")
        return []
    
    cards = []
    try:
        # Build search URL
        url = "https://api.scryfall.com/cards/search"
        params = {"q": name}
        if set_name:
            params["q"] += f" set:{set_name}"
        if set_number:
            params["q"] += f" number:{set_number}"
        
        response = requests.get(url, params=params, timeout=10)
        if response.status_code == 200:
            data = response.json()
            cards = data.get("data", [])
            
            # Store successful results to fallback data
            for card in cards:
                try:
                    store_mtg_card(card)
                except Exception as e:
                    logger.warning(f"Failed to store card {card.get('name', 'unknown')} to fallback: {e}")
            
            # Handle pagination if needed
            while data.get("has_more") and len(cards) < 100:  # Limit to prevent too many calls
                next_page = data.get("next_page")
                if not next_page:
                    break
                response = requests.get(next_page, timeout=10)
                if response.status_code == 200:
                    data = response.json()
                    more_cards = data.get("data", [])
                    cards.extend(more_cards)
                    
                    # Store additional cards to fallback data
                    for card in more_cards:
                        try:
                            store_mtg_card(card)
                        except Exception as e:
                            logger.warning(f"Failed to store card {card.get('name', 'unknown')} to fallback: {e}")
                else:
                    break
    except Exception as e:
        logger.error(f"Scryfall API error: {e}")
    
    return cards

def pokemontcg_search(name: str, set_name: Optional[str] = None, set_number: Optional[str] = None, api_key: Optional[str] = None, limit: int = 10, exact_match: bool = False) -> Tuple[List[Dict], int, int]:
    """Search Pokémon TCG API for cards with fallback"""
    # Check if fallback is enabled
    fallback_enabled = st.session_state.get("fallback_enabled", True)
    
    # Try API first
    try:
        cards = []
        total_count = 0
        page = 1
        
        if not api_key:
            if fallback_enabled:
                st.warning("Pokémon TCG API key not configured, using fallback data")
                return pokemontcg_search_fallback(name, set_name, set_number)
            else:
                st.warning("Pokémon TCG API key not configured and fallback data is disabled")
                return [], 0, 1
            
        # Build search query
        url = "https://api.pokemontcg.io/v2/cards"
        headers = {"X-Api-Key": api_key}
        
        # For exact match, prioritize name and set number without wildcards
        if exact_match and set_number:
            # Exact match with set number - fastest query
            params = {
                "q": f"name:\"{name}\" number:\"{set_number}\"",
                "page": page,
                "pageSize": limit
            }
            if set_name:
                params["q"] += f" set.name:\"{set_name}\""
        elif exact_match:
            # Exact name match
            params = {
                "q": f"name:\"{name}\"",
                "page": page,
                "pageSize": limit
            }
            if set_name:
                params["q"] += f" set.name:\"{set_name}\""
            if set_number:
                params["q"] += f" number:\"{set_number}\""
        else:
            # Standard wildcard search
            params = {
                "q": f"name:{name}*",
                "page": page,
                "pageSize": limit
            }
            if set_name:
                params["q"] += f" set.name:{set_name}*"
            if set_number:
                params["q"] += f" number:{set_number}*"
        
        # Make request with retry logic
        max_retries = 2  # Reduced retries for faster fallback
        for attempt in range(max_retries):
            try:
                response = requests.get(url, headers=headers, params=params, timeout=15)  # Reduced timeout
                response.raise_for_status()
                data = response.json()
                
                cards = data.get("data", [])
                total_count = data.get("totalCount", 0)
                page_count = data.get("pageCount", 1)
                break
                
            except requests.exceptions.Timeout:
                if attempt < max_retries - 1:
                    st.warning(f"Pokémon API timeout, retrying... ({attempt + 1}/{max_retries})")
                    time.sleep(1 ** attempt)  # Faster backoff
                else:
                    raise
            except requests.exceptions.RequestException as e:
                if attempt < max_retries - 1:
                    st.warning(f"Pokémon API error, retrying... ({attempt + 1}/{max_retries})")
                    time.sleep(1 ** attempt)
                else:
                    raise
        
        # If API returned no results, try fallback if enabled
        if not cards:
            if fallback_enabled:
                st.info("No results from API, trying fallback data...")
                return pokemontcg_search_fallback(name, set_name, set_number)
            else:
                st.info("No results from API and fallback data is disabled")
                return [], 0, 1
            
        return cards, total_count, page_count
        
    except Exception as e:
        if fallback_enabled:
            st.warning(f"Pokémon API failed: {e}. Using fallback data...")
            return pokemontcg_search_fallback(name, set_name, set_number)
        else:
            st.warning(f"Pokémon API failed: {e}. Fallback data is disabled.")
            return [], 0, 1

def pokemontcg_search_all(name: str, set_name: Optional[str] = None, set_number: Optional[str] = None, api_key: Optional[str] = None) -> Tuple[List[Dict], int, int]:
    """Search all Pokémon cards (higher limit) using multiple sources"""
    cards, total, _, _ = pokemontcg_search_multi_source(name, set_name, set_number, api_key, limit=250)
    return cards, total

def scryfall_card_price_summary(card: Dict) -> Dict[str, Optional[float]]:
    prices = card.get("prices", {})
    return {
        "usd": float(prices.get("usd")) if prices.get("usd") else None,
        "usd_foil": float(prices.get("usd_foil")) if prices.get("usd_foil") else None,
        "usd_etched": float(prices.get("usd_etched")) if prices.get("usd_etched") else None,
    }

def pokemontcg_price_summary(card: Dict) -> Dict[str, Optional[float]]:
    """Extract price information from Pokémon TCG API response"""
    try:
        tcgplayer = card.get("tcgplayer", {})
        prices = tcgplayer.get("prices", {})
        
        # Get different price types
        normal = prices.get("normal", {})
        holofoil = prices.get("holofoil", {})
        
        # Use the best available price
        low = None
        mid = None
        market = None
        
        # Try normal prices first
        if normal:
            low = float(normal.get("low", 0)) if normal.get("low") else None
            mid = float(normal.get("mid", 0)) if normal.get("mid") else None
            market = float(normal.get("market", 0)) if normal.get("market") else None
        
        # Fallback to holofoil if normal not available
        if not any([low, mid, market]) and holofoil:
            low = float(holofoil.get("low", 0)) if holofoil.get("low") else None
            mid = float(holofoil.get("mid", 0)) if holofoil.get("mid") else None
            market = float(holofoil.get("market", 0)) if holofoil.get("market") else None
            
        # Add fallback indicator
        if card.get("fallback"):
            # Show that this is fallback data
            pass
            
        return {"low": low, "mid": mid, "market": market}
        
    except Exception:
        return {"low": None, "mid": None, "market": None}

def scryfall_get_sets() -> Tuple[List[Dict], Optional[str]]:
    """Get all Magic: The Gathering sets from Scryfall API with complete field capture"""
    sets = []
    try:
        url = "https://api.scryfall.com/sets"
        page = 1
        
        while url:
            response = requests.get(url, timeout=30)
            response.raise_for_status()
            data = response.json()
            
            page_sets = data.get("data", [])
            sets.extend(page_sets)
            
            # Handle pagination
            if data.get("has_more"):
                url = data.get("next_page")
                page += 1
            else:
                break
                
    except Exception as e:
        return [], str(e)
    
    return sets, None

# Enhanced CSV handling functions for complete field capture
SCRYFALL_SET_FIELDS = [
    "object", "id", "code", "mtgo_code", "arena_code", "tcgplayer_id", 
    "name", "uri", "scryfall_uri", "search_uri", "released_at", "set_type", 
    "card_count", "digital", "nonfoil_only", "foil_only", "icon_svg_uri",
    "parent_set_code", "block_code", "block", "printed_size",
    "digital_size", "foil_only_printed_size", "nonfoil_only_printed_size",
    "mkm_id", "mkm_name", "related_uris", "purchase_uris", "booster_types"
]

# Game Type to Set Type mapping
GAME_TYPE_MAPPING = {
    "Main": ["core", "expansion", "masters", "eternal", "masterpiece", "from_the_vault", "starter", "draft_innovation"],
    "Digital": ["alchemy", "treasure_chest"],
    "Commander": ["arsenal", "spellbook", "commander"],
    "Planechase": ["planechase"],
    "Pre-Built": ["premium_deck", "duel_deck", "archenemy"],
    "Vanguard": ["vanguard"],
    "Funny": ["funny"],
    "Other": ["box", "promo", "token", "memorabilia", "minigame"]
}

def get_game_type(set_type):
    """Get game type based on set type"""
    if not set_type:
        return "Other"
    set_type = set_type.lower()
    for game_type, set_types in GAME_TYPE_MAPPING.items():
        if set_type in set_types:
            return game_type
    return "Other"

def flatten_set_data(set_data: Dict) -> Dict:
    """Flatten nested set data for CSV storage"""
    flattened = {}
    
    # Add all direct fields
    for field in SCRYFALL_SET_FIELDS:
        value = set_data.get(field, '')
        if value is None:
            value = ''
        elif isinstance(value, (dict, list)):
            # Convert complex objects to JSON strings
            value = json.dumps(value)
        flattened[field] = value
    
    # Add game_type
    set_type = set_data.get('set_type', '')
    flattened['game_type'] = get_game_type(set_type)
    
    # Add metadata
    flattened['last_updated'] = datetime.now().isoformat()
    
    return flattened

def load_existing_sets(csv_file: str) -> Dict[str, Dict]:
    """Load existing sets from CSV into a dict keyed by set code"""
    existing_sets = {}
    
    if not os.path.exists(csv_file):
        return existing_sets
    
    try:
        with open(csv_file, 'r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:
                set_code = row.get('code', '')
                if set_code:
                    existing_sets[set_code] = row
    except Exception as e:
        print(f"Error loading existing sets: {e}")
        return {}
    
    return existing_sets

def compare_sets(existing: Dict, new: Dict) -> bool:
    """Compare two sets to see if they need updating"""
    # Check if any SCRYFALL_SET_FIELDS are missing from existing data
    for field in SCRYFALL_SET_FIELDS:
        if field not in existing or existing.get(field) == '':
            # Field is missing or empty, need update
            return True
    
    # Compare key fields that might change
    key_fields = ['name', 'card_count', 'released_at', 'set_type', 'digital']
    
    for field in key_fields:
        existing_val = str(existing.get(field, '')).strip()
        new_val = str(new.get(field, '')).strip()
        if existing_val != new_val:
            return True
    
    return False

def update_sets_csv_enhanced(csv_file: str, sets_data: List[Dict], force_update: bool = False) -> Tuple[int, int, int]:
    """Update sets CSV with incremental changes, returns (new_count, updated_count, total_count)"""
    # Load existing sets
    existing_sets = load_existing_sets(csv_file)
    
    # Prepare all fields for CSV
    all_fieldnames = set(SCRYFALL_SET_FIELDS)
    all_fieldnames.add('game_type')
    all_fieldnames.add('last_updated')
    
    # Add any fields that might exist in existing CSV
    if existing_sets:
        existing_fields = set()
        for set_data in existing_sets.values():
            existing_fields.update(set_data.keys())
        all_fieldnames.update(existing_fields)
    
    fieldnames = sorted(list(all_fieldnames))
    
    # Process updates
    updated_sets = []
    new_sets = []
    unchanged_sets = []
    
    for set_data in sets_data:
        set_code = set_data.get('code', '')
        if not set_code:
            continue
        
        flattened = flatten_set_data(set_data)
        
        if set_code in existing_sets:
            existing = existing_sets[set_code]
            if force_update or compare_sets(existing, flattened):
                updated_sets.append((set_code, flattened, existing))
            else:
                unchanged_sets.append(set_code)
        else:
            new_sets.append((set_code, flattened))
    
    if not new_sets and not updated_sets and not force_update:
        return len(new_sets), len(updated_sets), len(existing_sets)
    
    # Create backup if there are changes
    if (new_sets or updated_sets) and os.path.exists(csv_file):
        backup_file = csv_file.replace('.csv', f'_backup_{datetime.now().strftime("%Y%m%d_%H%M%S")}.csv')
        try:
            os.rename(csv_file, backup_file)
        except:
            pass  # Continue even if backup fails
    
    # Write updated CSV
    with open(csv_file, 'w', newline='', encoding='utf-8') as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        
        # Write unchanged existing sets
        for set_code in unchanged_sets:
            writer.writerow(existing_sets[set_code])
        
        # Write new sets
        for set_code, flattened in new_sets:
            writer.writerow(flattened)
        
        # Write updated sets
        for set_code, flattened, old_data in updated_sets:
            writer.writerow(flattened)
    
    return len(new_sets), len(updated_sets), len(existing_sets) + len(new_sets)

def load_sets_from_csv(csv_file: str) -> List[Dict]:
    """Load sets from CSV file (replaces JSON cache loading)"""
    sets = []
    if not os.path.exists(csv_file):
        return sets
    
    try:
        with open(csv_file, 'r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:
                # Convert string representations back to proper types
                if row.get('card_count') and row['card_count'].isdigit():
                    row['card_count'] = int(row['card_count'])
                if row.get('digital') == 'True':
                    row['digital'] = True
                elif row.get('digital') == 'False':
                    row['digital'] = False
                if row.get('nonfoil_only') == 'True':
                    row['nonfoil_only'] = True
                elif row.get('nonfoil_only') == 'False':
                    row['nonfoil_only'] = False
                if row.get('foil_only') == 'True':
                    row['foil_only'] = True
                elif row.get('foil_only') == 'False':
                    row['foil_only'] = False
                
                # Parse JSON fields back to objects
                json_fields = ['related_uris', 'purchase_uris', 'booster_types', 'images', 'legalities']
                for field in json_fields:
                    if row.get(field) and (row[field].startswith('[') or row[field].startswith('{')):
                        try:
                            row[field] = json.loads(row[field])
                        except:
                            # If parsing fails, set appropriate default
                            if field == 'images':
                                row[field] = {}
                            elif field == 'legalities':
                                row[field] = {}
                            else:
                                row[field] = []
                
                sets.append(row)
    except Exception as e:
        print(f"Error loading CSV: {e}")
    
    return sets

def clear_csv_cache(csv_file):
    """Clear CSV cache and any corresponding JSON file"""
    if os.path.exists(csv_file):
        os.remove(csv_file)
    # Also remove corresponding JSON if it exists
    json_file = csv_file.replace('.csv', '.json')
    if os.path.exists(json_file):
        os.remove(json_file)


def justtcg_search(name: str, set_name: Optional[str] = None, api_key: Optional[str] = None, limit: int = 60) -> Tuple[List[Dict], Optional[str], Optional[str]]:
    """Search for cards using JustTCG API"""
    if not api_key:
        return [], "API key not configured", None
    
    try:
        headers = {
            "X-API-Key": api_key,
            "Content-Type": "application/json"
        }
        
        # Build search query
        query = name
        if set_name:
            query += f" {set_name}"
        
        # Make request to JustTCG cards endpoint
        url = "https://api.justtcg.com/v1/cards"
        params = {
            "q": query,
            "game": "pokemon"
        }
        
        response = requests.get(url, headers=headers, params=params, timeout=30)
        response.raise_for_status()
        data = response.json()
        
        cards = []
        api_source = "JustTCG"
        
        if isinstance(data, list):
            for card in data:
                # Extract card information
                card_data = {
                    "id": card.get("id"),
                    "name": card.get("name"),
                    "game": card.get("game"),
                    "set": card.get("set"),
                    "set_name": card.get("set_name"),
                    "number": card.get("number"),
                    "rarity": card.get("rarity"),
                    "tcgplayerId": card.get("tcgplayerId"),
                    "details": card.get("details"),
                    "variants": card.get("variants", []),
                    "api_source": api_source
                }
                cards.append(card_data)
        
        return cards, None, api_source
        
    except requests.exceptions.RequestException as e:
        return [], f"JustTCG API request failed: {e}", None
    except Exception as e:
        return [], f"JustTCG search error: {e}", None

def justtcg_card_price_summary(card: Dict) -> Dict[str, Optional[float]]:
    """Extract price summary from JustTCG card data"""
    try:
        variants = card.get("variants", [])
        if not variants:
            return {"market": None, "low": None, "mid": None}
        
        # Find Near Mint Normal variant as default
        nm_normal_price = None
        lowest_price = None
        highest_price = None
        
        for variant in variants:
            price = variant.get("price")
            if price is None:
                continue
                
            condition = variant.get("condition", "").lower()
            printing = variant.get("printing", "").lower()
            
            # Track lowest and highest prices
            if lowest_price is None or price < lowest_price:
                lowest_price = price
            if highest_price is None or price > highest_price:
                highest_price = price
            
            # Near Mint Normal is typically the "market" price
            if "near mint" in condition and "normal" in printing:
                nm_normal_price = price
        
        # Use Near Mint Normal as market price, fallback to average
        market_price = nm_normal_price or ((lowest_price + highest_price) / 2 if lowest_price and highest_price else None)
        
        return {
            "market": market_price,
            "low": lowest_price,
            "mid": market_price  # JustTCG doesn't separate mid, use market
        }
        
    except Exception:
        return {"market": None, "low": None, "mid": None}

def pokemontcg_get_sets(api_key: Optional[str] = None) -> Tuple[List[Dict], Optional[str]]:
    """Get all Pokémon sets"""
    try:
        if not api_key:
            return [], "API key not configured"
            
        url = "https://api.pokemontcg.io/v2/sets"
        headers = {"X-Api-Key": api_key}
        
        # Make request with retry logic
        max_retries = 3
        for attempt in range(max_retries):
            try:
                response = requests.get(url, headers=headers, timeout=30)
                response.raise_for_status()
                data = response.json()
                
                sets = data.get("data", [])
                return sets, None
                
            except requests.exceptions.Timeout:
                if attempt < max_retries - 1:
                    time.sleep(2 ** attempt)  # Exponential backoff
                else:
                    raise
            except requests.exceptions.RequestException as e:
                if attempt < max_retries - 1:
                    time.sleep(2 ** attempt)
                else:
                    raise
        
    except Exception as e:
        return [], str(e)

def get_scryfall_image_url(card: Dict) -> Optional[str]:
    # Prefer large, then normal; handle MDFC via card_faces
    try:
        imgs = card.get("image_uris") or {}
        for key in ("large", "normal", "png"):
            if imgs.get(key):
                return imgs[key]
        faces = card.get("card_faces") or []
        for face in faces:
            face_imgs = face.get("image_uris") or {}
            for key in ("large", "normal", "png"):
                if face_imgs.get(key):
                    return face_imgs[key]
    except Exception:
        pass
    return None

def scryfall_get_set_total(set_uri: Optional[str]) -> Optional[int]:
    """Get total cards in a set from Scryfall"""
    if not set_uri:
        return None
    try:
        response = requests.get(set_uri, timeout=10)
        response.raise_for_status()
        data = response.json()
        return data.get("printed_size") or data.get("card_count")
    except Exception:
        return None

def get_pokemontcg_image_url(card: Dict) -> Optional[str]:
    try:
        imgs = card.get("images") or {}
        return imgs.get("large") or imgs.get("small")
    except Exception:
        return None

