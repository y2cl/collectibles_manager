{
  "name": "collectibles-manager",
  "version": "2.2.1",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run backend\" \"npm run frontend\"",
    "backend": ".venv-backend/bin/uvicorn backend.main:app --reload --port 8002 --host 0.0.0.0",
    "frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "package-lock.json": "^1.0.0",
    "package.json": "^2.0.1"
  }
}
