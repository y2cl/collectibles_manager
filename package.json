{
  "name": "collectibles-manager",
  "private": true,
  "scripts": {
    "dev":      "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run backend\" \"npm run frontend\"",
    "backend":  ".venv-backend/bin/uvicorn backend.main:app --reload --port 8000",
    "frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
